    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0031",
      "blockType": "paragraph",
      "chunkId": "ck_page_news_002_go_121_release_0001",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "Today the Go team is thrilled to release Go 1.21, which you can get by visiting the download page .",
      "headingPath": [
        "Go 1.21 is released!"
      ],
      "order": 30,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0031",
      "sourceRefId": "src_page_news_002_go_121_release_0031",
      "textHash": "sha256_ff88eb45ed9a62690a1941cec431a56a",
      "textQuote": "Today the Go team is thrilled to release Go 1.21, which you can get by visiting the download page ."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0032",
      "blockType": "paragraph",
      "chunkId": "ck_page_news_002_go_121_release_0002",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "Go 1.21 is packed with new features and improvements. Here are some of the notable changes; for the full list, refer to the release notes .",
      "headingPath": [
        "Go 1.21 is released!"
      ],
      "order": 31,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0032",
      "sourceRefId": "src_page_news_002_go_121_release_0032",
      "textHash": "sha256_23d102cf707b3f67d52e6cf13b018fb5",
      "textQuote": "Go 1.21 is packed with new features and improvements. Here are some of the notable changes; for the full list, refer to the release notes ."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0033",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0002",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "The Profile Guided Optimization (PGO) feature we announced for preview in 1.20 is now generally available! If a file named default.pgo is present in the main package’s directory, the go command will use it to enable a PGO build. See the PGO documentation for more details. We’ve measured the impact of PGO on a wide set of Go programs and see performance impro",
      "headingPath": [
        "Go 1.21 is released!",
        "Tool improvements"
      ],
      "order": 32,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0033",
      "sourceRefId": "src_page_news_002_go_121_release_0033",
      "textHash": "sha256_657a2068c54394c8fc1690c0eb22468e",
      "textQuote": "The Profile Guided Optimization (PGO) feature we announced for preview in 1.20 is now generally available! If a file named default.pgo is present in the main package’s directory, the go command will use it to enable a PG"
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0034",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0002",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "The go tool now supports backward and forward language compatibility.",
      "headingPath": [
        "Go 1.21 is released!",
        "Tool improvements"
      ],
      "order": 33,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0034",
      "sourceRefId": "src_page_news_002_go_121_release_0034",
      "textHash": "sha256_01aba3d3277444ad26f92aa5f7aa028d",
      "textQuote": "The go tool now supports backward and forward language compatibility."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0035",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0002",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "New built-in functions: min, max and clear .",
      "headingPath": [
        "Go 1.21 is released!",
        "Language changes"
      ],
      "order": 34,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0035",
      "sourceRefId": "src_page_news_002_go_121_release_0035",
      "textHash": "sha256_89b36101692e7b1a806449a77b26d621",
      "textQuote": "New built-in functions: min, max and clear ."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0036",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0002",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "Several improvements to type inference for generic functions. The description of type inference in the spec has been expanded and clarified.",
      "headingPath": [
        "Go 1.21 is released!",
        "Language changes"
      ],
      "order": 35,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0036",
      "sourceRefId": "src_page_news_002_go_121_release_0036",
      "textHash": "sha256_170f66651e7e27c715415b0f9830d0ec",
      "textQuote": "Several improvements to type inference for generic functions. The description of type inference in the spec has been expanded and clarified."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0037",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0002",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "In a future version of Go we’re planning to address one of the most common gotchas of Go programming: loop variable capture . Go 1.21 comes with a preview of this feature that you can enable in your code using an environment variable. See the LoopvarExperiment wiki page for more details.",
      "headingPath": [
        "Go 1.21 is released!",
        "Language changes"
      ],
      "order": 36,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0037",
      "sourceRefId": "src_page_news_002_go_121_release_0037",
      "textHash": "sha256_dc4eba0bd322d1e96d65966fcdfc26ad",
      "textQuote": "In a future version of Go we’re planning to address one of the most common gotchas of Go programming: loop variable capture . Go 1.21 comes with a preview of this feature that you can enable in your code using an environ"
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0038",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0002",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "New log/slog package for structured logging.",
      "headingPath": [
        "Go 1.21 is released!",
        "Standard library additions"
      ],
      "order": 37,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0038",
      "sourceRefId": "src_page_news_002_go_121_release_0038",
      "textHash": "sha256_bc28fbca1aa5fc81ecb0cbe932c2798e",
      "textQuote": "New log/slog package for structured logging."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0039",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0002",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "New slices package for common operations on slices of any element type. This includes sorting functions that are generally faster and more ergonomic than the sort package.",
      "headingPath": [
        "Go 1.21 is released!",
        "Standard library additions"
      ],
      "order": 38,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0039",
      "sourceRefId": "src_page_news_002_go_121_release_0039",
      "textHash": "sha256_8813ecc013e721c59f4c24b8422b3da6",
      "textQuote": "New slices package for common operations on slices of any element type. This includes sorting functions that are generally faster and more ergonomic than the sort package."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0040",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0002",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "New maps package for common operations on maps of any key or element type.",
      "headingPath": [
        "Go 1.21 is released!",
        "Standard library additions"
      ],
      "order": 39,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0040",
      "sourceRefId": "src_page_news_002_go_121_release_0040",
      "textHash": "sha256_745f7abb3b5f0f9b1c3e8537fb7dfc6f",
      "textQuote": "New maps package for common operations on maps of any key or element type."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0041",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0003",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "New cmp package with new utilities for comparing ordered values.",
      "headingPath": [
        "Go 1.21 is released!",
        "Standard library additions"
      ],
      "order": 40,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0041",
      "sourceRefId": "src_page_news_002_go_121_release_0041",
      "textHash": "sha256_9488f785bb64efe5fdd7dc1d994889c4",
      "textQuote": "New cmp package with new utilities for comparing ordered values."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0042",
      "blockType": "paragraph",
      "chunkId": "ck_page_news_002_go_121_release_0003",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "In addition to the performance improvements when enabling PGO:",
      "headingPath": [
        "Go 1.21 is released!",
        "Improved performance"
      ],
      "order": 41,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0042",
      "sourceRefId": "src_page_news_002_go_121_release_0042",
      "textHash": "sha256_a0ea0ed0e8a3621d15652673cfed6a1c",
      "textQuote": "In addition to the performance improvements when enabling PGO:"
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0043",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0003",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "The Go compiler itself has been rebuilt with PGO enabled for 1.21, and as a result it builds Go programs 2-4% faster, depending on the host architecture.",
      "headingPath": [
        "Go 1.21 is released!",
        "Improved performance"
      ],
      "order": 42,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0043",
      "sourceRefId": "src_page_news_002_go_121_release_0043",
      "textHash": "sha256_51ddd58840848f489a12a657640061e8",
      "textQuote": "The Go compiler itself has been rebuilt with PGO enabled for 1.21, and as a result it builds Go programs 2-4% faster, depending on the host architecture."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0044",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0003",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "Due to tuning of the garbage collector, some applications may see up to a 40% reduction in tail latency.",
      "headingPath": [
        "Go 1.21 is released!",
        "Improved performance"
      ],
      "order": 43,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0044",
      "sourceRefId": "src_page_news_002_go_121_release_0044",
      "textHash": "sha256_2124a51263fe54dee1e408c0cfea410c",
      "textQuote": "Due to tuning of the garbage collector, some applications may see up to a 40% reduction in tail latency."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0045",
      "blockType": "list_item",
      "chunkId": "ck_page_news_002_go_121_release_0003",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "Collecting traces with runtime/trace now incurs a substantially smaller CPU cost on amd64 and arm64.",
      "headingPath": [
        "Go 1.21 is released!",
        "Improved performance"
      ],
      "order": 44,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0045",
      "sourceRefId": "src_page_news_002_go_121_release_0045",
      "textHash": "sha256_83f5ba4d512624a157ca29b2ff0bdf41",
      "textQuote": "Collecting traces with runtime/trace now incurs a substantially smaller CPU cost on amd64 and arm64."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0046",
      "blockType": "paragraph",
      "chunkId": "ck_page_news_002_go_121_release_0003",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "Go 1.21 adds an experimental port for WebAssembly System Interface (WASI) , Preview 1 ( GOOS=wasip1 , GOARCH=wasm ).",
      "headingPath": [
        "Go 1.21 is released!",
        "A new port to WASI"
      ],
      "order": 45,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0046",
      "sourceRefId": "src_page_news_002_go_121_release_0046",
      "textHash": "sha256_a26b8ccf880c72bb87a450e28fa2e4d7",
      "textQuote": "Go 1.21 adds an experimental port for WebAssembly System Interface (WASI) , Preview 1 ( GOOS=wasip1 , GOARCH=wasm )."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0047",
      "blockType": "paragraph",
      "chunkId": "ck_page_news_002_go_121_release_0003",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "To facilitate writing more general WebAssembly (Wasm) code, the compiler also supports a new directive for importing functions from the Wasm host: go:wasmimport .",
      "headingPath": [
        "Go 1.21 is released!",
        "A new port to WASI"
      ],
      "order": 46,
      "pageId": "page_news_002_go_121_release",
      "paragraphId": "pg_page_news_002_go_121_release_0047",
      "sourceRefId": "src_page_news_002_go_121_release_0047",
      "textHash": "sha256_de964c3ee773560c186241589aaa2ce2",
      "textQuote": "To facilitate writing more general WebAssembly (Wasm) code, the compiler also supports a new directive for importing functions from the Wasm host: go:wasmimport ."
    },
    {
      "blockId": "block_pg_page_news_002_go_121_release_0048",
      "blockType": "paragraph",
      "chunkId": "ck_page_news_002_go_121_release_0003",
      "confidence": 0.92,
      "contentHash": "sha256_38106c7beba23cf13ae881765fe6cdbc97c9744cc37a5f39eefd1b3205bec1a0",
      "fallbackText": "Thanks to everyone who contributed to this release by writing code, filing bugs, sharing feedback, and testing the release candidates. Your efforts helped to ensure that Go 1.21 is as stable as possible. As always, if you notice any problems, please file an issue .",
      "headingPath": [
        "Go 1.21 is released!",
        "A new port to WASI"
      ],
