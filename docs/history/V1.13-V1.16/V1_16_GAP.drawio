          <mxGeometry height="120" width="220" x="330" y="170" as="geometry" />
        </mxCell>
        <mxCell id="step3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=15;align=center" value="3 策略检查&#xa;runtime command 走 allowlist&#xa;非授权命令 default deny" vertex="1">
          <mxGeometry height="120" width="220" x="600" y="170" as="geometry" />
