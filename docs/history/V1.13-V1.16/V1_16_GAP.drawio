        <mxCell id="step4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#4F46E5;fontSize=15;align=center" value="4 生成 payload&#xa;runtime evidence / diff / workbench&#xa;所有事实绑定 artifact refs" vertex="1">
