  <diagram id="v116-plan" name="06 开发验收与出门条件">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="V1.16 开发计划、验收门槛与出门条件" style="text;html=1;fontSize=28;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="310" y="30" width="880" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m0" value="V1.16-0&#xa;合同冻结与外部审计&#xa;冻结 schema / MCP / E2E / blocker 合同&#xa;No-Go：未审计就开工" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;align=center" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="V1.16-1&#xa;Executable Schema&#xa;字段级 schema + validator API&#xa;验收：坏 payload 不落库" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;align=center" vertex="1" parent="1">
          <mxGeometry x="350" y="150" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="V1.16-2&#xa;Real MCP Server&#xa;stdio entrypoint + 4 tools&#xa;验收：HTTP / CLI / MCP parity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;fontSize=14;align=center" vertex="1" parent="1">
          <mxGeometry x="640" y="150" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="V1.16-3&#xa;External Repo E2E&#xa;四类仓库 / 本地快照 / 授权网络&#xa;验收：每行 artifactIds + pass/blocker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#4F46E5;fontSize=14;align=center" vertex="1" parent="1">
          <mxGeometry x="930" y="150" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="V1.16-4&#xa;Final Acceptance&#xa;schema tests / parity tests / E2E matrix / regression&#xa;验收：final report + PRD review + false-green audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=14;align=center" vertex="1" parent="1">
          <mxGeometry x="1220" y="150" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="gate" value="最终出门条件&#xa;1. 100% persisted public evidence artifacts 通过 schema 校验&#xa;2. HTTP / CLI / MCP envelope 与错误语义等价&#xa;3. 四类外部仓库矩阵完成，或 blocker 被接受&#xa;4. Workbench 展示 MCP / external evidence 且事实可追溯&#xa;5. V1.13-V1.15 回归全绿&#xa;6. Final acceptance report 记录 PRD review 与 false-green audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#475569;fontSize=16;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="250" y="470" width="1000" height="260" as="geometry" />
        </mxCell>
      </root>
