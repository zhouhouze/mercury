  <diagram id="v116-evidence-flow" name="05 关键证据流转路径">
    <mxGraphModel dx="1404" dy="628" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=28;fontStyle=1;align=center" value="V1.16 关键证据流转：从请求到 Workbench 可审计事实" vertex="1">
          <mxGeometry height="50" width="1080" x="210" y="30" as="geometry" />
        </mxCell>
        <mxCell id="step1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;align=center" value="1 请求进入&#xa;HTTP / CLI / MCP&#xa;携带 requestId、projectId、payload" vertex="1">
          <mxGeometry height="120" width="220" x="60" y="170" as="geometry" />
