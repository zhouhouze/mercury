        <mxCell id="service" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#475569;fontSize=16;fontStyle=1;align=center" value="Shared Evidence Service&#xa;&#xa;唯一业务实现路径&#xa;request normalization&#xa;policy check&#xa;runtime evidence&#xa;snapshot diff&#xa;workbench builder" vertex="1">
          <mxGeometry height="200" width="310" x="500" y="330" as="geometry" />
