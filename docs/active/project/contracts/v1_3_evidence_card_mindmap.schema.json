{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "navia.v1_3.evidence_card_mindmap",
  "title": "Navia V1.3 Evidence Card Mindmap Contract",
  "$ref": "#/$defs/V13EvidenceCardAcceptanceReport",
  "$defs": {
    "EvidenceCardViewModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "viewModelId",
        "artifactId",
        "sourcePageId",
        "renderMode",
        "nodes",
        "edges",
        "sourcePanel",
        "interactionState",
        "fallbacks",
        "warnings"
      ],
      "properties": {
        "viewModelId": {
          "type": "string",
          "minLength": 1
        },
        "artifactId": {
          "type": "string",
          "minLength": 1
        },
        "sourcePageId": {
          "type": "string",
          "minLength": 1
        },
        "renderMode": {
          "enum": [
            "evidence_card",
            "mermaid_visual_fallback",
            "mermaid_source_fallback",
            "source_unavailable"
          ]
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/EvidenceCardNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceCardEdge"
          }
        },
        "sourcePanel": {
          "$ref": "#/$defs/EvidenceCardSourcePanel"
        },
        "interactionState": {
          "$ref": "#/$defs/EvidenceCardInteractionState"
        },
        "fallbacks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceCardFallback"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "EvidenceCardNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodeId",
        "label",
        "depth",
        "childNodeIds",
        "sourceRefIds",
        "sourceCount",
        "qualityState",
        "uiState",
        "tags"
      ],
      "properties": {
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "note": {
          "type": "string",
          "maxLength": 180
        },
        "depth": {
          "type": "integer",
          "minimum": 0
        },
        "parentNodeId": {
          "type": [
            "string",
            "null"
          ]
        },
        "childNodeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sourceRefIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sourceCount": {
          "type": "integer",
          "minimum": 0
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "qualityState": {
          "enum": [
            "ready",
            "degraded",
            "missing_source"
          ]
        },
        "uiState": {
          "enum": [
            "default",
            "hover",
            "focus",
            "selected",
            "neighbor_highlighted",
            "dimmed",
            "locating",
            "located",
            "fallback_shown",
            "blocked"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "degradedReason": {
          "type": [
            "string",
            "null"
          ]
        },
        "textQuote": {
          "type": [
            "string",
            "null"
          ]
        },
        "fallbackText": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "EvidenceCardEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edgeId",
        "sourceNodeId",
        "targetNodeId",
        "uiState"
      ],
      "properties": {
        "edgeId": {
          "type": "string",
          "minLength": 1
        },
        "sourceNodeId": {
          "type": "string",
          "minLength": 1
        },
        "targetNodeId": {
          "type": "string",
          "minLength": 1
        },
        "uiState": {
          "enum": [
            "default",
            "highlighted",
            "dimmed"
          ]
        }
      }
    },
    "EvidenceCardSourcePanel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "selectedNodeId",
        "sourceRefIds",
        "items"
      ],
      "properties": {
        "status": {
          "enum": [
            "empty",
            "ready",
            "locating",
            "located",
            "fallback_shown",
            "blocked"
          ]
        },
        "selectedNodeId": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceRefIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceCardSourceItem"
          }
        },
        "failureReason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "EvidenceCardSourceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceRefId",
        "displayText",
        "jumpbackStatus"
      ],
      "properties": {
        "sourceRefId": {
          "type": "string",
          "minLength": 1
        },
        "displayText": {
          "type": "string",
          "minLength": 1
        },
        "jumpbackStatus": {
          "enum": [
            "not_attempted",
            "locating",
            "dom_success",
            "fallback_shown",
            "blocked"
          ]
        },
        "failureReason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "EvidenceCardInteractionState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selectedNodeId",
        "hoveredNodeId",
        "focusedNodeId",
        "neighborNodeIds",
        "dimmedNodeIds"
      ],
      "properties": {
        "selectedNodeId": {
          "type": [
            "string",
            "null"
          ]
        },
        "hoveredNodeId": {
          "type": [
            "string",
            "null"
          ]
        },
        "focusedNodeId": {
          "type": [
            "string",
            "null"
          ]
        },
        "neighborNodeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dimmedNodeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "EvidenceCardFallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "visibleToUser"
      ],
      "properties": {
        "reason": {
          "enum": [
            "missing_node_source_map",
            "missing_source_ref",
            "mermaid_render_failed",
            "dom_jumpback_failed",
            "low_signal_page",
            "unknown"
          ]
        },
        "visibleToUser": {
          "type": "boolean"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "V13EvidenceCardAcceptanceReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "stage",
        "passed",
        "summary",
        "pages",
        "screenshots",
        "testCommands",
        "fatalIssues",
        "majorIssues",
        "claim"
      ],
      "properties": {
        "schemaVersion": {
          "const": "v1.3-evidence-card-mindmap-report"
        },
        "stage": {
          "const": "V1.3"
        },
        "passed": {
          "type": "boolean"
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "pagesTotal",
            "pagesPassed",
            "nativeSidePanelSamples",
            "evidenceCardSamples",
            "fallbackSamples"
          ],
          "properties": {
            "pagesTotal": {
              "type": "integer",
              "minimum": 8
            },
            "pagesPassed": {
              "type": "integer",
              "minimum": 0
            },
            "nativeSidePanelSamples": {
              "type": "integer",
              "minimum": 3
            },
            "evidenceCardSamples": {
              "type": "integer",
              "minimum": 3
            },
            "fallbackSamples": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "pages": {
          "type": "array",
          "minItems": 8,
          "items": {
            "$ref": "#/$defs/V13AcceptancePage"
          }
        },
        "screenshots": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/V13ScreenshotEvidence"
          }
        },
        "testCommands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TestCommand"
          }
        },
        "fatalIssues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "majorIssues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claim": {
          "const": "V1.3 Evidence Card Mindmap experience complete"
        }
      }
    },
    "V13AcceptancePage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pageId",
        "url",
        "category",
        "expectedRisk",
        "evidenceCardRendered",
        "sourcePanelVisible",
        "fallbackVisibleWhenNeeded",
        "conclusion"
      ],
      "properties": {
        "pageId": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "snapshotPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "category": {
          "type": "string"
        },
        "expectedRisk": {
          "enum": [
            "normal",
            "long_text",
            "duplicate_labels",
            "missing_source",
            "low_signal",
            "render_failure"
          ]
        },
        "evidenceCardRendered": {
          "type": "boolean"
        },
        "sourcePanelVisible": {
          "type": "boolean"
        },
        "fallbackVisibleWhenNeeded": {
          "type": "boolean"
        },
        "conclusion": {
          "enum": [
            "pass",
            "degraded",
            "fail"
          ]
        }
      }
    },
    "V13ScreenshotEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "screenshotPath",
        "pageUrl",
        "isNativeSidePanel",
        "containsWebPageBody",
        "containsNaviaPanel",
        "containsEvidenceCardMindmap",
        "containsSourcePanel",
        "result"
      ],
      "properties": {
        "screenshotPath": {
          "type": "string"
        },
        "metadataPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "pageUrl": {
          "type": "string"
        },
        "isNativeSidePanel": {
          "type": "boolean"
        },
        "containsWebPageBody": {
          "type": "boolean"
        },
        "containsNaviaPanel": {
          "type": "boolean"
        },
        "containsEvidenceCardMindmap": {
          "type": "boolean"
        },
        "containsSourcePanel": {
          "type": "boolean"
        },
        "result": {
          "enum": [
            "pass",
            "degraded",
            "fail"
          ]
        }
      }
    },
    "TestCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "status"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "status": {
          "enum": [
            "pass",
            "fail",
            "blocked"
          ]
        },
        "evidencePath": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
