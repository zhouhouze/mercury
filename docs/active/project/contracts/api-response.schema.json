{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NaviaApiResponse",
  "type": "object",
  "required": ["ok", "data", "error", "request_id"],
  "properties": {
    "ok": { "type": "boolean" },
    "data": {},
    "error": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["code", "message", "recoverable", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "recoverable": { "type": "boolean" },
            "details": { "type": "object" }
          },
          "additionalProperties": false
        }
      ]
    },
    "request_id": { "type": "string", "pattern": "^req_" }
  },
  "allOf": [
    {
      "if": { "properties": { "ok": { "const": true } } },
      "then": { "properties": { "error": { "type": "null" } } }
    },
    {
      "if": { "properties": { "ok": { "const": false } } },
      "then": { "properties": { "data": { "type": "null" } } }
    }
  ],
  "additionalProperties": false
}
