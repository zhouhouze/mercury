{
  "launcher": {
    "width": "48px",
    "height": "48px",
    "borderRadius": "15px",
    "backgroundColor": "rgba(255, 255, 255, 0.45)",
    "backdropFilter": "blur(20px)",
    "border": "1.5px solid rgba(255, 255, 255, 0.55)",
    "boxShadow": "rgba(5, 84, 75, 0.15) 0px 16px 40px 0px, rgba(0, 0, 0, 0.05) 0px 2px 6px 0px, rgba(255, 255, 255, 0.5) 0px 1px 0px 0px inset",
    "transition": "0.35s cubic-bezier(0.34, 1.56, 0.64, 1)",
    "transform": "none"
  },
  "svg": {
    "width": "24px",
    "height": "24px",
    "color": "rgb(1, 58, 51)",
    "transition": "transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)",
    "transform": "none"
  },
  "dot": {
    "top": "3px",
    "right": "3px",
    "width": "8px",
    "height": "8px",
    "border": "2px solid rgb(255, 255, 255)",
    "boxShadow": "rgba(28, 94, 55, 0.5) 0px 0px 6px 0px",
    "backgroundColor": "rgb(28, 94, 55)"
  }
}