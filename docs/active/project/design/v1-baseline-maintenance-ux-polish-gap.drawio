        <mxCell id="p6-bm0" value="BM-0 文档门禁&#xa;PRD / 架构 / 开发计划 / 验收计划 / stage gate / gap / drawio / readiness audit&#xa;验收：已通过，无 fatal / major" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=14;" vertex="1" parent="1">
