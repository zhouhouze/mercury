  <diagram id="bmux-08" name="08 风险路线与 No-Go 边界">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p8-title" value="风险路线与 No-Go 边界&#xa;任何越界或虚假验收风险都回到文档门禁或开发阶段" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0b5f54;strokeColor=#063b34;fontColor=#ffffff;fontStyle=1;fontSize=22;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="1480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p8-r1" value="风险 1：证据混用&#xa;把 v1_post_v1_hardening frozen baseline 当作 BM / UX 新证据&#xa;处理：打回 BM-1 / BM-5，要求独立 evidence package" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="100" y="150" width="390" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p8-r2" value="风险 2：UX polish 越界&#xa;新增顶级页面、产品浏览器自动操作、默认本地文件读取或最终 Monica-like UX 声明&#xa;处理：停止开发，回到 BM-0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="570" y="150" width="430" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p8-r3" value="风险 3：截图 false-green&#xa;只截图静态页面，没有覆盖 launcher / sidebar / Mindmap / source state / Debug / Settings&#xa;处理：打回 BM-4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="1080" y="150" width="390" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p8-r4" value="风险 4：Runtime 诊断缺失&#xa;Runtime 离线空白、reconnect 不清楚、health 无记录&#xa;处理：打回 BM-2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="180" y="390" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p8-r5" value="风险 5：source 状态混淆&#xa;fallback_shown 或 blocked 被写成 located&#xa;处理：打回 BM-3 / BM-4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="630" y="390" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p8-r6" value="风险 6：可见 Chrome 打扰用户&#xa;未提前告知、未关闭实例、浏览器发声&#xa;处理：优先 headless + mute-audio，必要时重新验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#b45309;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="1080" y="390" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p8-decision" value="最终判断规则&#xa;若 build / validator / Runtime health / 截图 / PRD review / false-green audit 任一出现 fatal 或 major：拒绝声明本阶段完成，回到对应子阶段。&#xa;若全部通过：仅允许 scoped baseline maintenance and UX polish passed regression acceptance." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0f766e;strokeWidth=2;fontStyle=1;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="240" y="680" width="1060" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p8-e1" edge="1" parent="1" source="p8-r1" target="p8-decision" style="endArrow=block;html=1;rounded=1;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p8-e2" edge="1" parent="1" source="p8-r2" target="p8-decision" style="endArrow=block;html=1;rounded=1;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p8-e3" edge="1" parent="1" source="p8-r3" target="p8-decision" style="endArrow=block;html=1;rounded=1;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p8-e4" edge="1" parent="1" source="p8-r4" target="p8-decision" style="endArrow=block;html=1;rounded=1;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p8-e5" edge="1" parent="1" source="p8-r5" target="p8-decision" style="endArrow=block;html=1;rounded=1;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p8-e6" edge="1" parent="1" source="p8-r6" target="p8-decision" style="endArrow=block;html=1;rounded=1;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
