          <mxGeometry x="470" y="390" width="330" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p6-bm5" value="BM-5 出门审计&#xa;HTML 报告 / PRD review / false-green audit / 人工 spot-check&#xa;验收：已通过，无 fatal / major，仅允许 scoped 声明" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="860" y="390" width="330" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p6-commands" value="固定命令&#xa;npm --prefix apps/chrome-extension run build&#xa;npm --prefix apps/chrome-extension run validate:post-v1-hardening&#xa;curl --noproxy &#39;*&#39; http://127.0.0.1:17861/v1/health" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0f766e;strokeWidth=2;fontSize=16;" vertex="1" parent="1">
