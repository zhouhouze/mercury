  </diagram>
  <diagram id="v1-mvp-cq-07" name="07 验收门槛与出门条件">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p7-title" value="验收门槛与出门条件&lt;br&gt;门槛必须映射到用户实际能体验到的内容理解质量" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=22;fontStyle=1" vertex="1" parent="1"><mxGeometry x="80" y="45" width="1340" height="80" as="geometry"/></mxCell>
        <mxCell id="p7-metrics" value="机器指标&lt;br&gt;contentUnderstandingScore &gt;= 0.82&lt;br&gt;summaryGroundingRate &gt;= 0.88&lt;br&gt;qaGroundingRate &gt;= 0.85&lt;br&gt;mindmapSemanticCoverageRate &gt;= 0.85&lt;br&gt;noiseLeakageRate &lt;= 0.08&lt;br&gt;evidenceExplainabilityScore &gt;= 0.8&lt;br&gt;jumpbackSemanticMatch = true 或正确 degraded / blocked" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15" vertex="1" parent="1"><mxGeometry x="110" y="175" width="430" height="250" as="geometry"/></mxCell>
        <mxCell id="p7-ux" value="用户可体验门槛&lt;br&gt;总结像正文归纳，不像标题列表&lt;br&gt;问答能说明证据来源&lt;br&gt;解释选区不混入站点壳&lt;br&gt;导图高层节点是主题 / 论点 / 事实 / 步骤 / 结论&lt;br&gt;反跳能说明为什么跳到这里" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15" vertex="1" parent="1"><mxGeometry x="595" y="175" width="430" height="250" as="geometry"/></mxCell>
        <mxCell id="p7-exit" value="出门条件&lt;br&gt;CQ-0 到 CQ-7 全部通过&lt;br&gt;manifest / gold-notes / report schema 全部通过&lt;br&gt;report 含 operator、categoryResults&lt;br&gt;gold notes 均 finalStrictEligible=true&lt;br&gt;独立 CQ report / HTML / screenshots 完整&lt;br&gt;PRD review 和 false-green audit 无 fatal / major&lt;br&gt;允许声明：CQ strict real-site acceptance passed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15" vertex="1" parent="1"><mxGeometry x="1080" y="175" width="360" height="315" as="geometry"/></mxCell>
        <mxCell id="p7-nogo" value="不得作为出门条件&lt;br&gt;完整 V1 complete / 最终 Monica-like UX complete / 复杂站点全量高质量通过 / 视频音频图片内容已理解 / RAG / Memory / Web Research ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16" vertex="1" parent="1"><mxGeometry x="180" y="580" width="1140" height="125" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v1-mvp-cq-08" name="08 False-Green 风险与备选路线">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p8-title" value="False-Green 风险与备选路线&lt;br&gt;风险不能被包装成通过，必须打回相应子阶段" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=22;fontStyle=1" vertex="1" parent="1"><mxGeometry x="80" y="45" width="1340" height="80" as="geometry"/></mxCell>
        <mxCell id="p8-fg" value="False-Green 阻断&lt;br&gt;QH passed 冒充 CQ strict passed&lt;br&gt;只提取标题 / 导航 / 首页卡片却声明理解正文&lt;br&gt;fallback / blocked 写成 located&lt;br&gt;marker 指向语义无关文本&lt;br&gt;截图隐藏虚影 / 重叠 / 截断" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15" vertex="1" parent="1"><mxGeometry x="90" y="175" width="390" height="245" as="geometry"/></mxCell>
        <mxCell id="p8-route" value="验收路线优先级&lt;br&gt;1 Headless + mute-audio 真实网页自动化&lt;br&gt;2 必要时可见 Chrome 截图，提前告知并关闭实例&lt;br&gt;3 登录 / 地区 / cookie wall 阻断则 degraded / blocked&lt;br&gt;4 同类别替代样本补位，但保留原失败样本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15" vertex="1" parent="1"><mxGeometry x="555" y="175" width="390" height="245" as="geometry"/></mxCell>
        <mxCell id="p8-boundary" value="能力边界&lt;br&gt;不理解视频画面 / 音频 / 图片像素&lt;br&gt;不新增 OCR/VLM/ASR&lt;br&gt;不做 Web Research / RAG / Memory&lt;br&gt;不读取默认本地文件&lt;br&gt;自动化浏览器只属于验收工具，不是产品能力" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15" vertex="1" parent="1"><mxGeometry x="1020" y="175" width="390" height="245" as="geometry"/></mxCell>
        <mxCell id="p8-fallback" value="打回策略&lt;br&gt;主内容 signals 错：打回 CQ-2 A&lt;br&gt;summary / QA / explain 无 grounding：打回 CQ-3&lt;br&gt;Mindmap 标题堆叠：打回 CQ-4&lt;br&gt;证据 UI 不清：打回 CQ-5&lt;br&gt;jumpback 语义不匹配：打回 CQ-6&lt;br&gt;报告 / 截图 / PRD review 不一致：打回 CQ-7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=16" vertex="1" parent="1"><mxGeometry x="230" y="570" width="1040" height="185" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
