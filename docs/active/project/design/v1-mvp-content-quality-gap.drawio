<mxfile host="app.diagrams.net" modified="2026-07-02T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="v1-mvp-cq-01" name="01 阶段目标与目标体验">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p1-title" value="V1-MVP-CQ 内容理解质量增强&lt;br&gt;QH 通过后，继续解决“看起来没有真正理解网页”的问题" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=24;fontStyle=1" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1340" height="90" as="geometry"/></mxCell>
        <mxCell id="p1-state" value="当前事实（绿色：已实现 / 已通过）&lt;br&gt;V1-MC 自动化候选通过&lt;br&gt;QH 48 页 expanded acceptance 通过&lt;br&gt;基础 MVP 可体验：launcher / sidebar / Chat / Mindmap / Source Evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" vertex="1" parent="1"><mxGeometry x="90" y="180" width="390" height="190" as="geometry"/></mxCell>
        <mxCell id="p1-problem" value="用户仍感到不足（黄色：需强化）&lt;br&gt;总结像标题提取&lt;br&gt;导图像卡片堆叠&lt;br&gt;解释选区混入站点壳 / 时间 / 图片序号&lt;br&gt;反跳能跳但证据关系不清" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16" vertex="1" parent="1"><mxGeometry x="555" y="180" width="390" height="190" as="geometry"/></mxCell>
        <mxCell id="p1-goal" value="本阶段目标（蓝色：待新增证据）&lt;br&gt;用 strict 样本和 gold notes 验证：&lt;br&gt;总结 / 问答 / 解释选区 / Mindmap / Source Evidence&lt;br&gt;都基于当前页主内容，而不是导航或站点壳" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16" vertex="1" parent="1"><mxGeometry x="1020" y="180" width="390" height="190" as="geometry"/></mxCell>
        <mxCell id="p1-flow" value="目标体验路径&lt;br&gt;真实网页打开 Navia -&gt; 读取当前页 -&gt; 总结优先表达正文 / 简介 / 图文说明 -&gt; 问答引用 source evidence -&gt; Mindmap 表达主题 / 论点 / 事实 / 步骤 / 结论 -&gt; 点击证据看到 located marker 或 fallback / blocked 理由" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=17" vertex="1" parent="1"><mxGeometry x="150" y="450" width="1200" height="145" as="geometry"/></mxCell>
        <mxCell id="p1-nogo" value="No-Go（红色：禁止声明）&lt;br&gt;完整 V1 complete / 最终 Monica-like UX complete / 复杂站点全量高质量通过 / 视频音频图片内容已理解 / RAG / Memory / Web Research / OCR/VLM/ASR / PPT / Deep Research / 多 Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16" vertex="1" parent="1"><mxGeometry x="150" y="660" width="1200" height="115" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
