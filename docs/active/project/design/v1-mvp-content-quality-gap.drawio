        <mxCell id="p6-prev" value="已完成输入&lt;br&gt;V1.3 Evidence Card Mindmap&lt;br&gt;V1.4 Reading Map&lt;br&gt;V1-MC candidate passed&lt;br&gt;V1-MVP-QH 48 页矩阵 passed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" vertex="1" parent="1"><mxGeometry x="110" y="190" width="360" height="180" as="geometry"/></mxCell>
        <mxCell id="p6-cq" value="CQ strict 矩阵&lt;br&gt;36+ real samples&lt;br&gt;24 QH core regression&lt;br&gt;12 high-risk real pages&lt;br&gt;每类 &gt;= 6，至少 5/6 pass&lt;br&gt;总计至少 34/36 pass" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16" vertex="1" parent="1"><mxGeometry x="570" y="190" width="360" height="180" as="geometry"/></mxCell>
        <mxCell id="p6-risk" value="高风险样本必须覆盖&lt;br&gt;B站视频详情页&lt;br&gt;小红书图文详情页&lt;br&gt;观察者网 / 新闻详情页&lt;br&gt;门户首页&lt;br&gt;技术文档 / 博客长文&lt;br&gt;低信号页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16" vertex="1" parent="1"><mxGeometry x="1030" y="190" width="360" height="180" as="geometry"/></mxCell>
        <mxCell id="p6-evidence" value="独立 CQ 证据包&lt;br&gt;sample-manifest.json + schema&lt;br&gt;gold-notes/*.json + schema + finalStrictEligible&lt;br&gt;report.json + schema + operator + categoryResults&lt;br&gt;acceptance-report.html&lt;br&gt;prd-review.md / false-green-audit.md&lt;br&gt;screenshots / evidence-manifest.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16" vertex="1" parent="1"><mxGeometry x="220" y="505" width="480" height="230" as="geometry"/></mxCell>
        <mxCell id="p6-aggregate" value="聚合边界&lt;br&gt;v1_mainline_closeout 只能在 CQ 独立证据通过后聚合&lt;br&gt;不得用 QH passed 或 mainline candidate passed 替代 CQ strict evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16" vertex="1" parent="1"><mxGeometry x="820" y="505" width="460" height="190" as="geometry"/></mxCell>
