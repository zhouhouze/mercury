  <diagram id="v1-mvp-cq-03" name="03 内容角色识别与 Grounding 链路">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p3-title" value="内容角色识别与 Grounding 链路&lt;br&gt;目标：总结 / 问答 / 解释选区都能追溯到当前页主内容证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=22;fontStyle=1" vertex="1" parent="1"><mxGeometry x="80" y="45" width="1340" height="80" as="geometry"/></mxCell>
        <mxCell id="p3-block" value="DOM block&lt;br&gt;标题、正文、简介、caption、评论、导航、推荐、广告" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=15" vertex="1" parent="1"><mxGeometry x="100" y="190" width="220" height="120" as="geometry"/></mxCell>
        <mxCell id="p3-role" value="ContentRoleSignals&lt;br&gt;body / lead / caption / author / time / interaction-supplement / noise" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15" vertex="1" parent="1"><mxGeometry x="400" y="190" width="260" height="120" as="geometry"/></mxCell>
        <mxCell id="p3-source" value="SourceRef / fallbackText&lt;br&gt;selector、domPath、textQuote、nearby heading、href/card hints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15" vertex="1" parent="1"><mxGeometry x="740" y="190" width="280" height="120" as="geometry"/></mxCell>
        <mxCell id="p3-output" value="Grounded outputs&lt;br&gt;summary / QA / explain selection&lt;br&gt;无法支撑则 degraded 或证据不足" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15" vertex="1" parent="1"><mxGeometry x="1100" y="190" width="280" height="120" as="geometry"/></mxCell>
        <mxCell id="p3-positive" value="正向内容角色&lt;br&gt;正文段落、简介、分节标题、作者 / 来源 / 时间、图片 caption / alt、可见评论或互动补充" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" vertex="1" parent="1"><mxGeometry x="180" y="430" width="500" height="155" as="geometry"/></mxCell>
        <mxCell id="p3-negative" value="噪声角色&lt;br&gt;导航、footer、推荐、广告、版权提示、cookie wall、登录墙、重复低价值文本、无关时间戳、图片序号" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16" vertex="1" parent="1"><mxGeometry x="820" y="430" width="500" height="155" as="geometry"/></mxCell>
        <mxCell id="p3-metrics" value="验收阈值&lt;br&gt;summaryGroundingRate &gt;= 0.88；qaGroundingRate &gt;= 0.85；noiseLeakageRate &lt;= 0.08；解释选区不得被站点壳主导" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=16" vertex="1" parent="1"><mxGeometry x="210" y="680" width="1080" height="105" as="geometry"/></mxCell>
        <mxCell id="p3-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=block;" edge="1" parent="1" source="p3-block" target="p3-role"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=block;" edge="1" parent="1" source="p3-role" target="p3-source"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p3-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=block;" edge="1" parent="1" source="p3-source" target="p3-output"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v1-mvp-cq-04" name="04 Mindmap 语义质量与 Source Evidence">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p4-title" value="Mindmap 语义质量与 Source Evidence&lt;br&gt;目标：节点不只是标题堆叠，而是带证据关系的主题结构" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=22;fontStyle=1" vertex="1" parent="1"><mxGeometry x="80" y="45" width="1340" height="80" as="geometry"/></mxCell>
        <mxCell id="p4-digest" value="PerceptionDigest&lt;br&gt;主内容优先&lt;br&gt;正文 / 简介 / caption / 互动补充" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15" vertex="1" parent="1"><mxGeometry x="90" y="190" width="250" height="125" as="geometry"/></mxCell>
        <mxCell id="p4-c" value="C Mindmap&lt;br&gt;主题归并、短标签、节点类型&lt;br&gt;topic / claim / fact / step / conclusion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15" vertex="1" parent="1"><mxGeometry x="430" y="190" width="270" height="125" as="geometry"/></mxCell>
        <mxCell id="p4-node" value="Evidence Card Node&lt;br&gt;sourceRefIds&lt;br&gt;textQuote / fallbackText&lt;br&gt;degradedReason" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15" vertex="1" parent="1"><mxGeometry x="790" y="190" width="270" height="125" as="geometry"/></mxCell>
        <mxCell id="p4-b" value="B Renderer&lt;br&gt;证据关系说明&lt;br&gt;窄侧栏无虚影 / 重叠 / 截断&lt;br&gt;source card 排序主内容优先" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15" vertex="1" parent="1"><mxGeometry x="1150" y="190" width="270" height="125" as="geometry"/></mxCell>
        <mxCell id="p4-jump" value="Source Jumpback&lt;br&gt;located：marker 可见且语义匹配&lt;br&gt;fallback_shown：证据可读且原因清楚&lt;br&gt;blocked：阻断原因明确" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" vertex="1" parent="1"><mxGeometry x="210" y="450" width="490" height="155" as="geometry"/></mxCell>
        <mxCell id="p4-nogo" value="False-Green 阻断&lt;br&gt;导航词 / 推荐标题 / 评论重复 / 无来源节点 / marker 指向无关文本 / 只用标题生成导图，均不得 strict pass" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16" vertex="1" parent="1"><mxGeometry x="820" y="450" width="490" height="155" as="geometry"/></mxCell>
        <mxCell id="p4-metrics" value="指标：mindmapSemanticCoverageRate &gt;= 0.85；evidenceExplainabilityScore &gt;= 0.8；jumpbackSemanticMatch = true 或正确 degraded / blocked" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=16" vertex="1" parent="1"><mxGeometry x="235" y="700" width="1030" height="90" as="geometry"/></mxCell>
        <mxCell id="p4-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=block;" edge="1" parent="1" source="p4-digest" target="p4-c"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p4-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=block;" edge="1" parent="1" source="p4-c" target="p4-node"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p4-e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=block;" edge="1" parent="1" source="p4-node" target="p4-b"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v1-mvp-cq-05" name="05 开发及验收计划">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p5-title" value="开发及验收计划&lt;br&gt;每个子阶段先文档审计，再开发，再真实数据验收，失败打回" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=22;fontStyle=1" vertex="1" parent="1"><mxGeometry x="80" y="45" width="1340" height="80" as="geometry"/></mxCell>
        <mxCell id="p5-0" value="CQ-0 文档门禁&lt;br&gt;PRD / 架构 / 计划 / 验收 / drawio 同步&lt;br&gt;状态：本轮执行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="70" y="180" width="250" height="115" as="geometry"/></mxCell>
        <mxCell id="p5-1" value="CQ-1 strict manifest + gold notes&lt;br&gt;36+ 样本、人工 gold&lt;br&gt;manifest / gold-notes schema 必须通过&lt;br&gt;gold 必须 finalStrictEligible=true&lt;br&gt;状态：待新增" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="385" y="180" width="250" height="145" as="geometry"/></mxCell>
        <mxCell id="p5-2" value="CQ-2 A Page Reading&lt;br&gt;内容角色、正文密度、噪声惩罚&lt;br&gt;状态：待修改" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="700" y="180" width="250" height="115" as="geometry"/></mxCell>
        <mxCell id="p5-3" value="CQ-3 Grounded summary / QA / explain&lt;br&gt;SourceRef 支撑，不足则 degraded&lt;br&gt;状态：待修改" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="1015" y="180" width="250" height="115" as="geometry"/></mxCell>
        <mxCell id="p5-4" value="CQ-4 C Mindmap&lt;br&gt;语义主题、节点类型、短标签、证据绑定&lt;br&gt;状态：待修改" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="220" y="400" width="250" height="115" as="geometry"/></mxCell>
        <mxCell id="p5-5" value="CQ-5 B Renderer&lt;br&gt;证据关系、source card 解释、窄侧栏可读&lt;br&gt;状态：待修改" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="535" y="400" width="250" height="115" as="geometry"/></mxCell>
        <mxCell id="p5-6" value="CQ-6 Content Script jumpback&lt;br&gt;marker 说明、fallback / blocked 语义一致&lt;br&gt;状态：待修改" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="850" y="400" width="250" height="115" as="geometry"/></mxCell>
        <mxCell id="p5-7" value="CQ-7 strict acceptance&lt;br&gt;34/36 pass、HTML 报告、PRD review、false-green audit&lt;br&gt;状态：待新增证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="1165" y="400" width="250" height="115" as="geometry"/></mxCell>
