        <mxCell id="p2-title" value="当前架构与 CQ 目标架构差异&lt;br&gt;必须使用具体代码实体、分层和状态，不接受“前端 / 后端 / AI”抽象图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=22;fontStyle=1" vertex="1" parent="1"><mxGeometry x="70" y="35" width="1360" height="82" as="geometry"/></mxCell>
        <mxCell id="p2-dom" value="宿主网页 DOM&lt;br&gt;状态：已存在输入&lt;br&gt;正文 / 标题 / 图片 caption / 作者 / 时间 / 评论&lt;br&gt;推荐 / 导航 / 广告 / cookie wall / 登录墙" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14" vertex="1" parent="1"><mxGeometry x="70" y="165" width="230" height="150" as="geometry"/></mxCell>
        <mxCell id="p2-page" value="apps/chrome-extension/src/pageContext.ts&lt;br&gt;状态：已实现需修改&lt;br&gt;当前：读取 DOM / metadata&lt;br&gt;CQ：ContentRoleSignals、selection、visible media metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="350" y="165" width="250" height="150" as="geometry"/></mxCell>
        <mxCell id="p2-a" value="A Page Reading&lt;br&gt;services/.../modules/page_reading/&lt;br&gt;状态：已实现需修改&lt;br&gt;CQ：正文密度、噪声惩罚、SourceRef / fallbackText 质量" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="650" y="165" width="250" height="150" as="geometry"/></mxCell>
        <mxCell id="p2-d" value="D Adapter / Agent Loop&lt;br&gt;services/.../agent_loop + adapters&lt;br&gt;状态：已实现保持边界&lt;br&gt;复用 ToolResult / Artifact，不新增 public API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="1"><mxGeometry x="950" y="165" width="250" height="150" as="geometry"/></mxCell>
        <mxCell id="p2-c" value="C Mindmap&lt;br&gt;services/.../modules/mindmap/&lt;br&gt;状态：已实现需修改&lt;br&gt;CQ：语义主题、短标签、nodeSourceMap、degraded reason" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="1250" y="165" width="210" height="150" as="geometry"/></mxCell>
        <mxCell id="p2-b" value="B Renderer&lt;br&gt;chat_renderer / mindmap_renderer&lt;br&gt;状态：已实现需修改&lt;br&gt;CQ：证据关系说明、窄侧栏可读、degraded 文案" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="270" y="470" width="270" height="145" as="geometry"/></mxCell>
        <mxCell id="p2-bridge" value="contentBridge.ts&lt;br&gt;状态：已实现需修改&lt;br&gt;用户触发 jumpback&lt;br&gt;located marker / fallback / blocked 语义一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1"><mxGeometry x="615" y="470" width="270" height="145" as="geometry"/></mxCell>
        <mxCell id="p2-evidence" value="CQ evidence + contracts&lt;br&gt;证据状态：未开发 / 待新增&lt;br&gt;合同状态：已落盘&lt;br&gt;evidence/v1_mvp_content_quality/&lt;br&gt;sample-manifest、gold-notes、report、HTML、screenshots&lt;br&gt;contracts: manifest / gold-notes / report schema&lt;br&gt;report: operator + categoryResults&lt;br&gt;gold: finalStrictEligible=true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1"><mxGeometry x="960" y="470" width="410" height="225" as="geometry"/></mxCell>
        <mxCell id="p2-edge1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;endArrow=block;" edge="1" parent="1" source="p2-dom" target="p2-page"><mxGeometry relative="1" as="geometry"/></mxCell>
