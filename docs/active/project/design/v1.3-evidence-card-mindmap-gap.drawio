        <mxCell id="claim" value="允许谨慎声明&#xa;V1.3 Evidence Card Mindmap B-layer experience baseline complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=18;fontStyle=1;align=center;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="570" width="450" height="110" as="geometry" />
        </mxCell>
        <mxCell id="noClaim" value="不得声明&#xa;完整 V1 complete&#xa;网页内悬浮球主体验 complete&#xa;C 语义标签质量 complete&#xa;Canvas Knowledge Map complete&#xa;V2 Memory / RAG ready&#xa;Web Research / PPT / Deep Research ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e5e7eb;strokeColor=#6b7280;fontSize=15;spacing=12;" vertex="1" parent="1">
