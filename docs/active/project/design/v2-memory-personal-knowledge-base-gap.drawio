" target="v-5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e-9" value="证据绑定" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-5" target="v-6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e-10" value="删除请求" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-5" target="v-7"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="v-11" value="Before Query&#10;删除前 Ask / Graph / Trace 能命中 source，记录 evidence refs。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="160" y="360" width="360" height="120" as="geometry" /></mxCell><mxCell id="v-12" value="Forget Verification&#10;删除后 Source Library、Ask、Graph、Trace 均不得继续命中。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="620" y="360" width="360" height="120" as="geometry" /></mxCell><mxCell id="v-13" value="False-Green 防线&#10;只隐藏 UI 卡片不算删除；fallback/blocked 不得冒充 located。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#d5f5df;strokeColor=#2e7d32;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1080" y="360" width="360" height="120" as="geometry" /></mxCell><mxCell id="e-14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-11" target="v-12"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id