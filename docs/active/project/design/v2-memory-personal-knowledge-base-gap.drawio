acing=10;fillColor=#d5f5df;strokeColor=#2e7d32;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1280" y="130" width="250" height="130" as="geometry" /></mxCell><mxCell id="e-8" value="fallback / mock-first" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-4" target="v-5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e-9" value="仅受控调用" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-5" target="v-6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e-10" value="禁止越界" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-6" target="v-7"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="v-11" value="真实产品化前必须复核&#10;repository / commit / version / auth / API snapshot / capability matrix / unsupported list / deletion semantics / path redaction。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="80" y="340" width="450" height="150" as="geometry" /></mxCell><mxCell id="v-12" value="状态返回要求&#10;Runtime online 后才返回 adapterStatus、dataServiceStatus、sourceBuildStatus；Runtime offline 由前端 transport failure 推导。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="580" y="340" width="450" height="150" as="geometry" /></mxCell><mxCell id="v-13" value="删除语义要求&#10;Forget 不是只隐藏 UI；必须影响 Source Library、Ask、Graph、Trace，并用 before/after query 证明。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#d5f5df;strokeColor=#2e7d32;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1080" y="340" width="450" height="150" as="geometry" /></mxCell></root></mxGraphModel></diagram><diagram id="v2-05" name="05 前端体验与服务状态 UX"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title-3" value="05 前端体验与服务状态 UX" style="text;html=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1;fontColor=#0b5d52;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="24" width="1260" height="44" as="geometry" /></mxCell><mxCell id="v-4" value="ServiceStatusBanner&#10;Runtime / Adapter / data_service 摘要&#10;保存前可见" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="70" y="120" width="320" height="120" as="geometry" /></mxCell><mxCell id="v-5" value="SaveToKnowledgeCard&#10;单次主动保存&#10;显示 queued/ingesting/building/trace_ready" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="440" y="120" width="320" height="120" as="geometry" /></mxCell><mxCell id="v-6" value="Knowledge Workspace&#10;workspace switcher / source library / detail" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="810" y="120" width="320" height="120" as="geometry" /></mxCell><mxCell id="v-7" value="Ask with Sources&#10;答案必须带 EvidenceRef 或 degraded reason" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1180" y="120" width="320" height="120" as="geometry" /></mxCell><mxCell id="e-8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-4" target="v-5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e-9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-5" target="v-6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e-10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-6" target="v-7"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="v-11" value="Knowledge Graph&#10;服务侧 source/unit/relation&#10;B 不凭空生成事实" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="70" y="340" width="320" height="120" as="geometry" /></mxCell><mxCell id="v-12" value="PermissionRoot&#10;默认关闭本地读取&#10;授权 / 撤销可审计" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="440" y="340" width="320" height="120" as="geometry" /></mxCell><mxCell id="v-13" value="ForgetSource&#10;二次确认&#10;before/after query 验证" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="810" y="340" width="320" height="120" as="geometry" /></mxCell><mxCell id="v-14" value="DataServiceStatusCard&#10;Debug / Settings 中解释 auth、version、unreachable" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#1f2933;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1180" y="340" width="320" height="120" as="geometry" /></mxCell><mxCell id="e-15" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-11" target="v-12"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e-16" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-12" target="v-13"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e-17" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#607d8b;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;" edge="1" parent="1" source="v-13" target="v-14"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="note-18" value="V2-7 验收必须截图证明：不同状态有不同文案、状态色和下一步动作。Runtime offline、Adapter blocked、data_service unreachable、source build failed 不得合并为一个 generic error。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d9e7e5;fontColor=#445;dashed=1;fontSize=13;align=left;spacing=8;" vertex="1" parent="1"><mxGeometry x="80" y="540" width="1420" height="120" as="geometry" /></mxCell></root></mxGraphModel></diagram><diagram id="v2-06" name="06 权限删除与证据链"><mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" p