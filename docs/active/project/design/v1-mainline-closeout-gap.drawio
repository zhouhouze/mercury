  <diagram id="v1mc-04" name="04 复杂站点质量链路">
    <mxGraphModel dx="1700" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1120" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t04" parent="1" value="04 复杂站点质量链路：B站详情页、噪声过滤与真实登录态证据" style="text;html=1;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1">
          <mxGeometry x="310" y="24" width="1180" height="52" as="geometry" />
        </mxCell>
        <mxCell id="scope04" parent="1" value="验收矩阵必须区分 public no-login、logged-in、degraded、blocked。低权限样本只能证明公开路径，不能替代登录态质量。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="230" y="86" width="1340" height="46" as="geometry" />
        </mxCell>
        <mxCell id="sites04" parent="1" value="输入站点样本&#10;- B站：首页 / 指定详情页&#10;- 小红书：首页 / 详情页&#10;- 观察者网：首页 / 详情页&#10;每页记录：URL、身份状态、Chrome route、截图路径" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="60" y="170" width="310" height="150" as="geometry" />
        </mxCell>
        <mxCell id="extract04" parent="1" value="pageContext.ts 抽取层&#10;优先主内容 signals：&#10;- video title / desc&#10;- UP主 / 发布时间&#10;- 播放 / 弹幕 / 投币收藏等核心 stats&#10;- 正文/文章标题/段落" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="430" y="170" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="noise04" parent="1" value="显式噪声黑名单&#10;- 首页、未经授权、禁止转载等模板语&#10;- 推荐列表、相关视频、自动连播&#10;- 弹幕设置、活动横幅、广告&#10;- QQ群/微信/商务私信/订阅合集" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="850" y="170" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="quality04" parent="1" value="A Page Reading 质量层&#10;- density ranking&#10;- sourceRef coverage&#10;- low-signal degraded&#10;- QualityReport 必须解释为什么通过/降级/失败" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="1270" y="170" width="400" height="150" as="geometry" />
        </mxCell>
        <mxCell id="summary04" parent="1" value="目标输出：总结/问答&#10;用户应看到：&#10;- 主内容优先&#10;- 信息密度高&#10;- 无模板噪声主导&#10;- public/logged-in 边界清楚" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="140" y="420" width="360" height="135" as="geometry" />
        </mxCell>
        <mxCell id="map04" parent="1" value="目标输出：Mindmap/Reading Map&#10;用户应看到：&#10;- 主题归并后节点少而清晰&#10;- 无文本虚影/重叠&#10;- 聊天框不截断&#10;- 节点能关联 source evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="560" y="420" width="400" height="135" as="geometry" />
        </mxCell>
        <mxCell id="jump04" parent="1" value="目标输出：Source Jumpback&#10;用户应看到：&#10;- located：正文区域高亮明确&#10;- fallback：证据卡说明原因&#10;- blocked：权限/环境阻塞清楚&#10;不得把三者合并成 success" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="1020" y="420" width="420" height="135" as="geometry" />
        </mxCell>
        <mxCell id="chrome04" parent="1" value="Chrome 路线选择&#10;A 用户登录态 CDP：最高保真&#10;B 专用 profile 登录：可回归&#10;C public no-login：仅公开路径&#10;D blocker + 人工截图：防 false-green" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="250" y="660" width="500" height="145" as="geometry" />
        </mxCell>
        <mxCell id="evidence04" parent="1" value="出门证据&#10;- report.json：身份状态、route、passed/degraded/blocked&#10;- acceptance-report.html：中文截图报告&#10;- prd-review.md / false-green-audit.md&#10;- screenshots：每个关键状态可见" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="810" y="660" width="520" height="145" as="geometry" />
        </mxCell>
        <mxCell id="nog04" parent="1" value="No-Go&#10;- B站详情页仍由推荐/弹幕设置/活动文字主导&#10;- public 样本写成 logged-in pass&#10;- 无截图却声明 UI 可读&#10;- Chrome 阻塞被静默跳过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="1390" y="660" width="320" height="145" as="geometry" />
        </mxCell>
        <mxCell id="e04a" edge="1" parent="1" source="sites04" target="extract04" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;" value="DOM/text signals">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e04b" edge="1" parent="1" source="extract04" target="noise04" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;" value="filter candidates">
