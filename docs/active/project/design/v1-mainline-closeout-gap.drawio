  <diagram id="v1mc-08" name="08 风险路线与备选技术">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t08" value="风险路线与备选技术：高风险不改写为通过" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1420" height="42" as="geometry" />
        </mxCell>
        <mxCell id="r8a" value="A 登录态 Chrome CDP&#xa;适用：路线 B 出错后，用户主动提供 NAVIA_CDP_URL，扩展已加载&#xa;优点：最接近真实登录态，适合作为复验路线&#xa;缺点：需人工配合，不能接管主 profile&#xa;允许：logged-in validation，仅限覆盖页面" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;spacing=8;arcSize=8;fillColor=#dbeafe;strokeColor=#1d4ed8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="330" height="135" as="geometry" />
        </mxCell>
        <mxCell id="r8b" value="B 首选 专用测试 profile / cookie 注入&#xa;适用：隔离 profile 可加载扩展，cookie 有效&#xa;优点：可重复，不污染主 profile&#xa;降级条件：专用 profile 或依赖缺失时转路线 A / C&#xa;允许：cookie-injected / dedicated-profile validation" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;spacing=8;arcSize=8;fillColor=#d5f5e3;strokeColor=#2e7d32;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="100" width="330" height="135" as="geometry" />
        </mxCell>
        <mxCell id="r8c" value="C public no-login headless&#xa;适用：登录态不可用但公开页面可访问&#xa;优点：低打扰、可静音、自动化稳定&#xa;缺点：不能证明登录态体验&#xa;允许：public no-login evidence" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;spacing=8;arcSize=8;fillColor=#dbeafe;strokeColor=#1d4ed8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="100" width="300" height="135" as="geometry" />
        </mxCell>
        <mxCell id="r8d" value="D blocker + 人工截图补位&#xa;适用：A/B/C 均不可用或证据不可信&#xa;优点：不做虚假验收&#xa;缺点：不能自动化出门&#xa;允许：blocked / manual review required" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;spacing=8;arcSize=8;fillColor=#ffd6d6;strokeColor=#c62828;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1110" y="100" width="330" height="135" as="geometry" />
        </mxCell>
        <mxCell id="r8e1" value="失败或不可用" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeWidth=2;strokeColor=#475569;" edge="1" parent="1" source="r8a" target="r8b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r8e2" value="失败或不可用" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeWidth=2;strokeColor=#475569;" edge="1" parent="1" source="r8b" target="r8c">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r8e3" value="失败或不可用" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeWidth=2;strokeColor=#475569;" edge="1" parent="1" source="r8c" target="r8d">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="risk1" value="小红书首页风险&#xa;虚拟列表 / 风控 / feed 文本拼接可能导致 source_not_found_in_dom&#xa;目标：feed card sourceRef + card/href/textQuote 多线索定位&#xa;No-Go：fresh validation fallback-only 不能 pass" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;spacing=8;arcSize=8;fillColor=#fff3bf;strokeColor=#b7791f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="310" width="390" height="130" as="geometry" />
        </mxCell>
        <mxCell id="risk2" value="观察者详情页风险&#xa;正文、评论、推荐、最新视频、侧栏混排&#xa;目标：article title / author / time / body 提权&#xa;No-Go：反跳到评论或推荐不能 pass" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;spacing=8;arcSize=8;fillColor=#fff3bf;strokeColor=#b7791f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="310" width="390" height="130" as="geometry" />
        </mxCell>
        <mxCell id="risk3" value="B站详情页风险&#xa;登录态、播放页噪声、推荐区、活动横幅、弹幕设置&#xa;目标：标题、简介、UP主、发布信息、播放/弹幕进入主节点&#xa;No-Go：public no-login 冒充 logged-in" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;spacing=8;arcSize=8;fillColor=#fff3bf;strokeColor=#b7791f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="310" width="390" height="130" as="geometry" />
        </mxCell>
        <mxCell id="risk4" value="E2E false-green 风险&#xa;自动化选择更易定位 source card，可能掩盖产品 UI 排序问题&#xa;要求：记录 selectedSourceCardIndex、reason、候选卡片和 UI 排序&#xa;No-Go：无选择原因却声明通过" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;spacing=8;arcSize=8;fillColor=#ffd6d6;strokeColor=#c62828;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="390" height="130" as="geometry" />
        </mxCell>
        <mxCell id="risk5" value="Mindmap / Reading Map 视觉风险&#xa;窄屏下文本虚影、节点重叠、卡片截断、输入框遮挡&#xa;要求：真实截图证明可读性&#xa;No-Go：只用 build / unit test 替代视觉验收" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;spacing=8;arcSize=8;fillColor=#fff3bf;strokeColor=#b7791f;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="500" width="390" height="130" as="geometry" />
        </mxCell>
        <mxCell id="risk6" value="出门判断&#xa;当前 real-site 6/6 pass、0 degraded、0 blocked，mainline closeout 为 automated candidate pass&#xa;V1-HR/CC 只支撑人工核查准备，不支撑完整 V1 complete&#xa;cookie-injected 证据不得冒充完整 logged-in 全站质量&#xa;人工 review 仍 pending" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;spacing=8;arcSize=8;fillColor=#fff2cc;strokeColor=#b38f00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="500" width="390" height="130" as="geometry" />
        </mxCell>
        <mxCell id="risk7" value="文档审查结论&#xa;当前文档足以指导 V1-HR/CC 人工产品核查准备阶段。&#xa;本阶段不进入产品代码实现。&#xa;后续人工体验或 fresh validation 若失败，必须保留 degraded / blocked，不得过度承诺。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;spacing=8;arcSize=8;fillColor=#f8fafc;strokeColor=#64748b;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="700" width="960" height="95" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
