  <diagram id="v1mc-05" name="05 开发及验收计划">
    <mxGraphModel dx="1700" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t05" parent="1" value="05 开发及验收计划：先审计、再开发、再端到端验收，失败即打回" style="text;html=1;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1">
          <mxGeometry x="260" y="24" width="1280" height="52" as="geometry" />
        </mxCell>
        <mxCell id="rule05" parent="1" value="每个子阶段开始前：从总 PRD 制定验收标准和开发计划，单独落盘审计意见；无新增 fatal / major 后才进入实质开发。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="250" y="86" width="1300" height="46" as="geometry" />
        </mxCell>
        <mxCell id="p0" parent="1" value="V1-MC-DOC-0&#10;文档/架构/drawio 基线&#10;输出：当前图、stage gate、acceptance plan、readiness audit&#10;出门：无 fatal/major 文档冲突" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="50" y="180" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p1" parent="1" value="V1-MC-QA-1&#10;Chrome 验收路线确认&#10;A CDP / B 专用 profile / C public / D blocker&#10;出门：route 写入报告，不能虚假通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="390" y="180" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p2" parent="1" value="V1-MC-QA-2&#10;B站指定详情页质量&#10;抽取主内容，压制推荐/模板/活动噪声&#10;出门：总结、导图、source 截图 fresh pass" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="730" y="180" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p3" parent="1" value="V1-MC-QA-3&#10;复杂站点矩阵&#10;B站/小红书/观察者网：首页+详情页&#10;出门：public/logged-in/degraded/blocked 分清" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="1070" y="180" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p4" parent="1" value="V1-MC-QA-4&#10;Mindmap/Reading Map/UI 可读性&#10;无文本虚影、重叠、截断、输入遮挡&#10;出门：真实 Chrome 截图 + 人类可读报告" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
          <mxGeometry x="1410" y="180" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p5" parent="1" value="V1-MC-QA-5&#10;总体验收报告&#10;report.json + acceptance-report.html + PRD review + false-green audit&#10;出门：仅能声明 automated candidate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;align=left;verticalAlign=top;spacing=8;arcSize=8;" vertex="1">
