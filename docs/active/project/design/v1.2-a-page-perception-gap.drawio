          <mxGeometry x="220" y="40" width="960" height="50" as="geometry" />
        </mxCell>
        <mxCell id="current10" value="当前 A-V1.1 / A-V1.2-0&#10;DOM baseline high-signal perception&#10;手写 HTML fixtures + deterministic digest&#10;HighSignal / Digest / SourceMap / QualityReport 合同已冻结&#10;&#10;限制&#10;复杂真实网页覆盖不足&#10;extractor ensemble 未实现&#10;质量评估尚未经过 100-page 校准&#10;A-V1.2-1+ 仍需外部复审后才能实现" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#DC2626;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="430" height="360" as="geometry" />
        </mxCell>
        <mxCell id="target10" value="目标 A-V1.2&#10;高质量网页感知层&#10;高质量网页感知&#10;+ 结构化页面摘要&#10;+ 可反跳证据&#10;+ Debug 可验证 JSON&#10;+ 100-page 真实验收&#10;&#10;收益&#10;D/C/B 获得高密度、可验证、可反跳的页面事实输入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="890" y="150" width="430" height="360" as="geometry" />
        </mxCell>
        <mxCell id="gap10" value="A-V1.2 必补 Gap&#10;A-V1.2-0 外部复审无 fatal / major risk&#10;100 个复杂网页 corpus + snapshotPath&#10;reviewed / semi_auto_accepted gold&#10;主体内容识别&#10;噪声过滤与密度提升&#10;结构化页面摘要&#10;SourceMap / SourceRef 反跳&#10;QualityReport + DebugEvidenceBundle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="530" y="570" width="340" height="250" as="geometry" />
