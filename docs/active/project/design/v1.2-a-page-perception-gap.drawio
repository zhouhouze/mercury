          <mxGeometry x="740" y="150" width="300" height="230" as="geometry" />
        </mxCell>
        <mxCell id="ux15d" value="用户可见结果&#10;摘要不是 raw text 压缩&#10;问答基于页面事实而非旧 session&#10;Mindmap 节点可回到原文或证据卡&#10;低信号页面明确不可读&#10;Debug 能解释质量分数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="1100" y="150" width="250" height="230" as="geometry" />
        </mxCell>
        <mxCell id="scenario15a" value="验收场景 1：普通文章 / 长文&#10;TLDR 和 key facts 比原文更短&#10;每个关键事实都有 SourceRef&#10;Debug 显示 pass 原因" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=14;align=left;spacing=12" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="scenario15b" value="验收场景 2：技术文档 / 代码页&#10;列表、代码块、表格事实保持结构&#10;摘要项不丢 heading / code context&#10;source fallback 可展示" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=14;align=left;spacing=12" vertex="1" parent="1">
          <mxGeometry x="400" y="500" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="scenario15c" value="验收场景 3：新闻 / 电商 / 论坛噪声页&#10;广告、推荐、评论、cookie、share bar 被过滤或降级&#10;filteredEvidence 能解释原因" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=14;align=left;spacing=12" vertex="1" parent="1">
          <mxGeometry x="720" y="500" width="260" height="150" as="geometry" />
        </mxCell>
        <mxCell id="scenario15d" value="验收场景 4：图片富集 / 低信号 / 中文页&#10;图片只基于 DOM metadata&#10;登录墙 / 付费墙 fail 或 degraded&#10;中文 digest 可读且有来源" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=14;align=left;spacing=12" vertex="1" parent="1">
          <mxGeometry x="1040" y="500" width="260" height="150" as="geometry" />
        </mxCell>
