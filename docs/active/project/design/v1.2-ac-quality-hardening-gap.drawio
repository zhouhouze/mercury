          <mxGeometry x="40" y="30" width="1480" height="60" as="geometry" />
        </mxCell>
        <mxCell id="go" value="必须通过&#xa;1. 12 个网页 / 6 类样本&#xa;2. 5 个原生 Side Panel 页面 E2E&#xa;3. 中文复杂页 + low-signal degraded&#xa;4. A quality 可解释&#xa;5. C digest-first 可证明&#xa;6. HTML 报告 + false-green audit" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="150" y="160" width="520" height="320" as="geometry" />
        </mxCell>
        <mxCell id="nogo" value="No-Go&#xa;1. 只跑离线 corpus&#xa;2. heading-only 冒充 digest-first&#xa;3. 节点无 sourceRef/fallbackText&#xa;4. Debug 不可读&#xa;5. low-signal pass&#xa;6. A/C/B 绕过 D&#xa;7. 引入 RAG/记忆/多 Agent/浏览器自动化/OCR/VLM/ASR" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="850" y="160" width="560" height="320" as="geometry" />
        </mxCell>
        <mxCell id="claim" value="完成后只能声明：V1.2-AC-Quality 阶段 A/C 质量深化通过。不得声明完整 V1.2 complete 或 A 100-page production gate complete。" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="250" y="620" width="1100" height="90" as="geometry" />
        </mxCell>
