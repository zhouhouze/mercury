        <mxCell id="title2" value="当前架构与目标架构差异" style="rounded=0;whiteSpace=wrap;html=1;fontSize=24;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1480" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cur" value="当前事实&#xa;1. Native UX 5 页已通过&#xa;2. A 有 high-signal 与 low-signal degraded 基线&#xa;3. C 已有 deterministic Mindmap&#xa;4. Debug 可展示基础状态和 JSON&#xa;5. 仍需更强真实网页矩阵和 digest-first 防线" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="90" y="150" width="560" height="300" as="geometry" />
        </mxCell>
        <mxCell id="target" value="本阶段目标&#xa;1. 至少 12 个真实网页或 snapshot&#xa;2. 至少 5 个原生 Side Panel 页面验收&#xa;3. A quality 可解释，low-signal 不 pass&#xa;4. C readiness pass 时必须 digest-first&#xa;5. Mindmap 节点有 sourceRef 或 fallbackReason&#xa;6. HTML 报告和 false-green audit 可追溯" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="860" y="150" width="560" height="300" as="geometry" />
        </mxCell>
        <mxCell id="gap1" value="Gap A：A 输出质量需要扩展到更多真实网页类别" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="240" y="540" width="360" height="70" as="geometry" />
        </mxCell>
        <mxCell id="gap2" value="Gap C：需要防止 heading-only fallback 被误声明为 digest-first" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="620" y="540" width="360" height="70" as="geometry" />
        </mxCell>
        <mxCell id="gap3" value="Gap Debug：需要人类可读质量解释，不只是原始 JSON" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1000" y="540" width="360" height="70" as="geometry" />
        </mxCell>
        <mxCell id="edgegap" edge="1" parent="1" source="cur" target="target" style="endArrow=block;html=1;rounded=0;strokeWidth=3;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
