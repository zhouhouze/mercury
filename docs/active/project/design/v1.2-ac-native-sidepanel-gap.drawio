        <mxCell id="p2-action" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#4F46E5;fontSize=15;spacing=12;" value="Chrome action / 快捷键&#xa;打开原生 Side Panel&#xa;不得用全屏插件页替代" vertex="1">
