  <diagram id="native-page-3" name="03 开发与验收计划">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p3-title" value="V1.2-AC-Native 开发与验收计划" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="40" width="1160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p3-0" value="0 合同与验收冻结&#xa;native-only 通过口径&#xa;截图标准&#xa;证据路径&#xa;No-Go" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="180" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p3-1" value="1 打开稳定化&#xa;manifest&#xa;background&#xa;sidePanel API&#xa;action / shortcut" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="160" width="180" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p3-2" value="2 UI 可达性&#xa;窄宽度布局&#xa;滚动与 tab&#xa;关键按钮可达&#xa;失败状态可见" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="160" width="180" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p3-3" value="3 自动化锚点&#xa;data-testid&#xa;native-probe&#xa;native-ux&#xa;blocker 输出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="160" width="180" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p3-4" value="4 完整路径&#xa;读取页面&#xa;Debug JSON&#xa;总结 / 问答&#xa;Mindmap / fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9333EA;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="960" y="160" width="180" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p3-5" value="5 出门验收&#xa;3 个真实网页&#xa;1 个中文复杂页&#xa;1 个 low-signal&#xa;PRD 复检" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;fontSize=15;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="160" width="180" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p3-e01" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#475569;endArrow=block;endFill=1;" edge="1" parent="1" source="p3-0" target="p3-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e12" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#475569;endArrow=block;endFill=1;" edge="1" parent="1" source="p3-1" target="p3-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e23" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#475569;endArrow=block;endFill=1;" edge="1" parent="1" source="p3-2" target="p3-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e34" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#475569;endArrow=block;endFill=1;" edge="1" parent="1" source="p3-3" target="p3-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e45" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#475569;endArrow=block;endFill=1;" edge="1" parent="1" source="p3-4" target="p3-5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-gate" value="每个子阶段固定流程&#xa;PRD 规格检视 -&gt; 开发计划与验收标准 -&gt; 预审计 -&gt; 闭环 fatal / major -&gt; 实质开发 -&gt; 真实 Chrome 验收 -&gt; PRD 复检 -&gt; 放行或打回" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#94A3B8;fontSize=18;fontStyle=1;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="120" y="460" width="1160" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p3-data" value="真实数据门槛&#xa;至少 3 个真实 Chrome 页面&#xa;至少 1 个中文复杂网页&#xa;至少 1 个 low-signal 页面 degraded / fail&#xa;每页保留 URL、截图、Runtime 状态、操作路径和结论" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFEFF;strokeColor=#0891B2;fontSize=17;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="220" y="640" width="960" height="140" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="native-page-4" name="04 用户路径与截图标准">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p4-title" value="用户体验路径与截图证据标准" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="40" width="1160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p4-path" value="用户路径&#xa;1 打开真实网页&#xa;2 点击扩展 action 或快捷键&#xa;3 右侧出现 Navia 原生 Side Panel&#xa;4 点击读取当前页面&#xa;5 查看 Debug 结构化感知&#xa;6 发起总结或问答&#xa;7 点击 Mindmap 并查看 source fallback&#xa;8 刷新或重开后确认恢复状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#5B7CFA;fontSize=18;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="90" y="150" width="520" height="520" as="geometry" />
        </mxCell>
        <mxCell id="p4-shot" value="通过截图必须包含&#xa;真实网页标题或正文&#xa;Chrome 原生右侧 Side Panel 边界&#xa;Navia 标识和 Runtime 状态&#xa;当前页读取状态或 Debug 状态&#xa;总结 / 问答 / Mindmap 的至少一个结果&#xa;同名 metadata JSON 可追溯" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7EF;strokeColor=#22C55E;fontSize=18;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="790" y="150" width="520" height="300" as="geometry" />
        </mxCell>
        <mxCell id="p4-bad" value="不得作为通过证据&#xa;只有全屏插件页&#xa;只有 Runtime API 输出无浏览器截图&#xa;只有 mock 页面或不可复现页面&#xa;截图看不出 Side Panel 是否打开&#xa;截图缺 metadata 或结论不一致&#xa;probe 通过但 native-ux 未通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=18;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="790" y="500" width="520" height="250" as="geometry" />
        </mxCell>
        <mxCell id="p4-e1" value="native UX evidence" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0F766E;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="p4-path" target="p4-shot">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="native-page-5" name="05 出门条件与No-Go">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5-title" value="出门条件与 No-Go" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="40" width="1160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p5-go" value="Go 条件&#xa;原生 Side Panel 可稳定打开&#xa;截图同时包含网页和右侧 Navia&#xa;每张通过截图有 metadata JSON&#xa;读取、Debug、总结、问答、Mindmap 全部在 Side Panel 内完成&#xa;native-ux 通过或人工等价截图通过&#xa;3 个真实网页、1 个中文复杂页、1 个 low-signal 页通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=17;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="90" y="150" width="570" height="310" as="geometry" />
        </mxCell>
        <mxCell id="p5-nogo" value="No-Go 条件&#xa;全屏 chrome-extension 页面冒充原生 Side Panel&#xa;截图没有真实网页或没有右侧 Navia&#xa;关键按钮不可达&#xa;自动化无法定位但直接 pass&#xa;blocker 缺 schema 或 blocksCompletion=true&#xa;probe 通过冒充 native-ux 通过&#xa;B 绕过 Runtime 或 D 直接生成结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=17;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="740" y="150" width="570" height="310" as="geometry" />
        </mxCell>
        <mxCell id="p5-exit" value="最终阶段声明&#xa;可以声明 V1.2-AC-Native 完成：原生 Side Panel 中 AC 功能链路可用。&#xa;不得声明完整 V1.2 complete、A-V1.2 100-page gate complete、最终聊天体验 complete。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=19;fontStyle=1;spacing=16;" vertex="1" parent="1">
          <mxGeometry x="180" y="560" width="1040" height="150" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
