        <mxCell id="p2-b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;spacing=12;" value="B SidePanel Shell&#xa;Chat / Debug / Mermaid / Source Fallback&#xa;只渲染，不拥有 AgentCore 状态" vertex="1">
          <mxGeometry height="170" width="230" x="540" y="150" as="geometry" />
        </mxCell>
        <mxCell id="p2-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDFA;strokeColor=#0D9488;fontSize=15;spacing=12;" value="Extension Background Proxy&#xa;连接 127.0.0.1 Runtime&#xa;处理权限、origin、runtime offline" vertex="1">
          <mxGeometry height="130" width="210" x="860" y="170" as="geometry" />
        </mxCell>
        <mxCell id="p2-runtime" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;spacing=12;" value="Runtime API Gateway&#xa;/v1/page/context&#xa;/v1/chat/stream&#xa;/v1/trace" vertex="1">
          <mxGeometry height="130" width="210" x="1100" y="170" as="geometry" />
        </mxCell>
        <mxCell id="p2-d" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;fontSize=15;spacing=12;" value="D Adapter Layer&#xa;唯一 ToolResult / Artifact / Event / Trace 映射出口&#xa;不被 A/C/B 绕过" vertex="1">
          <mxGeometry height="140" width="260" x="1075" y="420" as="geometry" />
        </mxCell>
        <mxCell id="p2-a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFCCB;strokeColor=#65A30D;fontSize=15;spacing=12;" value="A Page Perception&#xa;StructuredPage / HighSignal / Digest / SourceMap / QualityReport&#xa;不创建 Artifact、不发 SSE" vertex="1">
          <mxGeometry height="140" width="300" x="220" y="640" as="geometry" />
        </mxCell>
        <mxCell id="p2-c" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9333EA;fontSize=15;spacing=12;" value="C Mindmap&#xa;优先消费 PerceptionDigest + SourceRef&#xa;生成 Mermaid 与 nodeSourceMap&#xa;不读取 DOM" vertex="1">
          <mxGeometry height="140" width="300" x="890" y="640" as="geometry" />
        </mxCell>
        <mxCell id="p2-e1" edge="1" parent="1" source="p2-web" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;endArrow=block;endFill=1;" target="p2-action">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-e2" edge="1" parent="1" source="p2-action" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;endArrow=block;endFill=1;" target="p2-b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-e3" edge="1" parent="1" source="p2-b" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;endArrow=block;endFill=1;" target="p2-bg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-e4" edge="1" parent="1" source="p2-bg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;endArrow=block;endFill=1;" target="p2-runtime">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-e5" edge="1" parent="1" source="p2-runtime" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;endArrow=block;endFill=1;" target="p2-d">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-e6" edge="1" parent="1" source="p2-d" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#65A30D;endArrow=block;endFill=1;" target="p2-a">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-e7" edge="1" parent="1" source="p2-d" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9333EA;endArrow=block;endFill=1;" target="p2-c">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2-e8" edge="1" parent="1" source="p2-d" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#0F766E;endArrow=block;endFill=1;fontSize=13;" target="p2-b" value="渲染结果回到 Side Panel">
