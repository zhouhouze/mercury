        <mxCell id="goal" value="目标体验&#xa;接近 Monica 在 YouTube 的视频助手体验：视频概览、章节、Mindmap、Ask Video、证据和时间戳跳转" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;spacing=12;align=left;" vertex="1" parent="1"><mxGeometry x="90" y="120" width="410" height="170" as="geometry"/></mxCell>
        <mxCell id="bili" value="B站体验标杆&#xa;AI课代表 / BibiGPT / NoteGPT 式省流总结、章节大纲、视频导图、字幕搜索、继续追问、时间戳定位" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=16;spacing=12;align=left;" vertex="1" parent="1"><mxGeometry x="545" y="120" width="410" height="170" as="geometry"/></mxCell>
        <mxCell id="scope" value="阶段边界&#xa;当前只做文档规划，不进入代码实现。V3.0 先做 Transcript-first；V3.x 再规划 ASR / VLM / OCR / Gemini Video / Live input。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=16;spacing=12;align=left;" vertex="1" parent="1"><mxGeometry x="1000" y="120" width="410" height="170" as="geometry"/></mxCell>
        <mxCell id="refs" value="竞品参考&#xa;Monica Video Summarizer&#xa;AI课代表&#xa;BibiGPT&#xa;NoteGPT Bilibili Summarizer&#xa;Eightify / HARPA&#xa;YouTube conversational AI&#xa;Gemini Video Understanding" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontSize=16;spacing=14;align=left;" vertex="1" parent="1"><mxGeometry x="90" y="340" width="1320" height="190" as="geometry"/></mxCell>
        <mxCell id="nogo" value="不得声明&#xa;V3.0 implemented / 完整 Monica-like parity / 视频画面或音频已理解 / ASR VLM OCR Gemini Video ready / 直播理解 ready / 跨视频 RAG ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;spacing=12;align=center;" vertex="1" parent="1"><mxGeometry x="190" y="600" width="1120" height="130" as="geometry"/></mxCell>
