  <diagram id="v12-gap-10" name="10 当前阶段 AC 联动路线">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0" />
