        <mxCell id="ac10_title" value="当前阶段：先优化 A，再补强 C，最后完成 AC 联动验收" style="text;html=1;fontSize=26;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="260" y="30" width="1080" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ac10_now" value="当前实现事实&#xa;&#xa;A：已有 StructuredPageContext / HighSignal / Digest / SourceMap / QualityReport 与 107-page evidence&#xa;&#xa;C：已有 Mermaid generator / validator / repair once / nodeSourceMap&#xa;&#xa;D：已有 CoreProvider + Adapter Layer，c_mindmap_adapter 已接入&#xa;&#xa;缺口：A 高信号结果还不是主链路稳定消费事实；C 还未优先消费 A Digest / SourceRef" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#D97706;fontSize=14;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="360" height="270" as="geometry" />
        </mxCell>
        <mxCell id="ac10_target" value="目标架构&#xa;&#xa;/v1/page/context&#xa;-> A perception bundle&#xa;   structuredPage&#xa;   highSignalPage&#xa;   perceptionDigest&#xa;   sourceMap / SourceRef&#xa;   qualityReport&#xa;-> Session.activePage.perception&#xa;-> D readiness gate&#xa;-> C digest-first mindmap&#xa;-> Artifact + Debug + source fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFEFF;strokeColor=#0891B2;fontSize=14;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="470" y="120" width="370" height="270" as="geometry" />
        </mxCell>
        <mxCell id="ac10_accept" value="验收门槛&#xa;&#xa;1. Runtime 主链路可见 A JSON&#xa;2. Debug 展示 quality pass / degraded / fail 原因&#xa;3. C 节点优先来自 PerceptionDigest.items&#xa;4. nodeSourceMap 绑定 A SourceRef&#xa;5. 每个主要节点有 textQuote 或 fallbackText&#xa;6. Mermaid validator 通过，repair &lt;= 1&#xa;7. D 负责 ToolResult / Artifact / Event / Trace&#xa;8. 12 个真实网页 + 3 个真实 Chrome 页面验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;fontSize=14;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="900" y="120" width="640" height="270" as="geometry" />
