        <mxCell id="http4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=14;align=left;spacing=12" value="外部 HTTP API 不新增&#xa;POST /v1/page/context&#xa;POST /v1/chat/stream (SSE)&#xa;GET trace by session/turn" vertex="1">
