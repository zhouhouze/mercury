  <diagram id="v12-gap-05" name="05 关键体验路径信息流转">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title5" value="关键体验路径信息流转：泳道 + 调用路径 + 数据对象" style="text;html=1;fontSize=26;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="430" y="30" width="540" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lanes5" value="泳道：Chrome / Runtime / A / D Adapter Layer / CoreProvider(piAgent) / C / B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#334155;fontSize=14;align=center" vertex="1" parent="1">
          <mxGeometry x="90" y="95" width="1220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="path1" value="1 读取当前页面&#xa;Chrome DOM → /v1/page/context → A build_structured_page_context → StructuredPageContext → session.activePage&#xa;关键对象：PageReadingInput / StructuredPageContext / contentHash / paragraphId / chunkId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFEFF;strokeColor=#0891B2;fontSize=14;align=left;spacing=12" vertex="1" parent="1">
          <mxGeometry x="90" y="180" width="1220" height="105" as="geometry" />
        </mxCell>
        <mxCell id="path2" value="2 总结网页&#xa;User → /v1/chat/stream → D Adapter Layer builds CoreTurnInput → piAgentProvider.run_turn → summary AdapterInvocation → ToolResult → ArtifactRecord → AgentEvent SSE → B Chat + Artifact Renderer&#xa;关键对象：CoreTurnInput / AdapterInvocation / ToolResult / ArtifactRecord / AgentEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=14;align=left;spacing=12" vertex="1" parent="1">
          <mxGeometry x="90" y="315" width="1220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="path3" value="3 连续问答&#xa;User follow-up → D builds CoreTurnInput(activePage + recentMessages) → piAgentProvider → answer AdapterInvocation → ToolResult → response.delta / response.done → B Chat Renderer&#xa;关键对象：recentMessages / StructuredPageContext / CoreTurnResult / AgentEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=14;align=left;spacing=12" vertex="1" parent="1">
          <mxGeometry x="90" y="465" width="1220" height="115" as="geometry" />
        </mxCell>
        <mxCell id="path4" value="4 Mindmap 与反跳&#xa;User asks mindmap → D Adapter Layer → C generate_mindmap_payload → MindmapResult(nodeSourceMap) → D maps ArtifactRecord → B Mindmap Renderer → node click → source paragraph / excerpt fallback&#xa;关键对象：MindmapInput / MindmapResult / nodeSourceMap / ArtifactRecord.metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;fontSize=14;align=left;spacing=12" vertex="1" parent="1">
          <mxGeometry x="90" y="610" width="1220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="trace5" value="所有路径都必须写入 Trace：state / intent / budget / adapter / tool / artifact / response / error；trace?turn_id 可还原主路径" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#475569;fontSize=14;align=center" vertex="1" parent="1">
          <mxGeometry x="250" y="775" width="900" height="70" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
