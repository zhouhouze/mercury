        </mxCell>
        <mxCell id="exit6" value="出门交付&#xa;A module tests pass&#xa;fixture evidence 可审计&#xa;public-api / architecture / implementation-plan / test plan 同步&#xa;stage gate 记录 Go / No-Go&#xa;Integration Codex 可基于 A 输出接入 D/C" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="960" y="150" width="320" height="300" as="geometry" />
        </mxCell>
        <mxCell id="review6" value="审计要求&#xa;若真实数据验收失败，打回开发计划。&#xa;若出现重大规格偏差或虚假验收风险，停止并找人类确认。&#xa;A 完成不等于 V1.2 complete，必须等 Integration wiring 和 E2E 通过。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
