        <mxCell id="current1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#DC2626;fontSize=15;align=left;spacing=14" value="当前基线&#xa;PageContext / cleanedText / headings&#xa;文本传递为主&#xa;结构化段落与 chunk 不稳定&#xa;图片 / 表格 / 代码块 / OCR / 媒体仅有零散规划&#xa;&#xa;风险&#xa;D/C 需要重新解析 raw text&#xa;source reference 不稳定&#xa;容易产生假理解和 false green" vertex="1">
          <mxGeometry height="380" width="430" x="80" y="150" as="geometry" />
