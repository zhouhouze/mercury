        <mxCell id="gap1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;fontSize=15;align=left;spacing=14" value="必须补齐的 Gap&#xa;A-V1.0-0 合同冻结&#xa;A-V1.0-1 文本 / DOM 结构识别&#xa;A-V1.0-2 图文 DOM 元数据识别&#xa;A-V1.0-3 OCR 合同规划&#xa;A-V1.0-4 表格 / 列表 / 代码块识别&#xa;A-V1.0-5 页面区域与信息密度识别&#xa;A-V2.0-* 视频 / 直播规划登记" vertex="1">
