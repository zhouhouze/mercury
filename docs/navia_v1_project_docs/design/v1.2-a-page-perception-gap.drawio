  <diagram id="a-gap-01" name="01 A 当前架构 vs 目标架构差异">
    <mxGraphModel dx="1652" dy="739" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title1" parent="1" style="text;html=1;fontSize=28;fontStyle=1;align=center" value="A 模块当前架构 vs 目标架构差异" vertex="1">
          <mxGeometry height="50" width="880" x="260" y="40" as="geometry" />
        </mxCell>
        <mxCell id="current1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#DC2626;fontSize=15;align=left;spacing=14" value="当前基线&#xa;PageContext / cleanedText / headings&#xa;文本传递为主&#xa;结构化段落与 chunk 不稳定&#xa;图片 / 表格 / 代码块 / OCR / 媒体仅有零散规划&#xa;&#xa;风险&#xa;D/C 需要重新解析 raw text&#xa;source reference 不稳定&#xa;容易产生假理解和 false green" vertex="1">
          <mxGeometry height="380" width="430" x="80" y="150" as="geometry" />
        </mxCell>
        <mxCell id="target1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=15;align=left;spacing=14" value="目标 A：Page Perception / AgentCore Eyes&#xa;StructuredPageContext&#xa;ParagraphBlock[]&#xa;PageChunk[]&#xa;HeadingTree&#xa;ParagraphAnnotation[]&#xa;Density / importance / confidence&#xa;source reference 可追踪&#xa;&#xa;收益&#xa;D 可直接构建 CoreTurnInput&#xa;C 可直接生成 source-mapped mindmap&#xa;B 只渲染 D/C 产物" vertex="1">
          <mxGeometry height="380" width="430" x="880" y="150" as="geometry" />
        </mxCell>
        <mxCell id="gap1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;fontSize=15;align=left;spacing=14" value="必须补齐的 Gap&#xa;A-V1.0-0 合同冻结&#xa;A-V1.0-1 文本 / DOM 结构识别&#xa;A-V1.0-2 图文 DOM 元数据识别&#xa;A-V1.0-3 OCR 合同规划&#xa;A-V1.0-4 表格 / 列表 / 代码块识别&#xa;A-V1.0-5 页面区域与信息密度识别&#xa;A-V2.0-* 视频 / 直播规划登记" vertex="1">
          <mxGeometry height="250" width="340" x="530" y="590" as="geometry" />
        </mxCell>
        <mxCell id="edge1a" edge="1" parent="1" source="current1" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#64748B" target="gap1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge1b" edge="1" parent="1" source="gap1" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#64748B" target="target1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
