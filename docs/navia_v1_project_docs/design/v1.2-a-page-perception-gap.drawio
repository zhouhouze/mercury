          <mxGeometry x="300" y="40" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="go6" value="Go 条件&#xa;真实 fixture 全部通过&#xa;稳定 paragraphId / chunkId / contentHash&#xa;annotations 引用已有 paragraph&#xa;chunks 保持页面顺序&#xa;empty page -&gt; PAGE_CONTEXT_REQUIRED&#xa;evidence JSON + assertion log 已登记&#xa;PRD 复检无重大偏差" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="390" height="300" as="geometry" />
        </mxCell>
