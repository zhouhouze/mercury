  <diagram id="a-gap-06" name="06 验收门槛与出门条件">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title6" value="A 验收门槛与出门条件" style="text;html=1;fontSize=28;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="300" y="40" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="go6" value="Go 条件&#xa;真实 fixture 全部通过&#xa;稳定 paragraphId / chunkId / contentHash&#xa;annotations 引用已有 paragraph&#xa;chunks 保持页面顺序&#xa;empty page -&gt; PAGE_CONTEXT_REQUIRED&#xa;evidence JSON + assertion log 已登记&#xa;PRD 复检无重大偏差" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="390" height="300" as="geometry" />
        </mxCell>
        <mxCell id="nogo6" value="No-Go 条件&#xa;生成 summary / answer / mindmap artifact&#xa;发 SSE 或写 EventStore&#xa;直接调用 D/C/B、MCP、Skill、外部 API&#xa;直接调用 OCR / 视觉 / 视频 / 直播 engine&#xa;无来源描述图片内容&#xa;把 A-V2.0 视频 / 直播规划声明为 V1.2 完成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#DC2626;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="520" y="150" width="390" height="300" as="geometry" />
        </mxCell>
        <mxCell id="exit6" value="出门交付&#xa;A module tests pass&#xa;fixture evidence 可审计&#xa;public-api / architecture / implementation-plan / test plan 同步&#xa;stage gate 记录 Go / No-Go&#xa;Integration Codex 可基于 A 输出接入 D/C" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="960" y="150" width="320" height="300" as="geometry" />
        </mxCell>
        <mxCell id="review6" value="审计要求&#xa;若真实数据验收失败，打回开发计划。&#xa;若出现重大规格偏差或虚假验收风险，停止并找人类确认。&#xa;A 完成不等于 V1.2 complete，必须等 Integration wiring 和 E2E 通过。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=15;align=left;spacing=14" vertex="1" parent="1">
          <mxGeometry x="250" y="570" width="900" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
