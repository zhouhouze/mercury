<mxfile host="app.diagrams.net" modified="2026-06-03T00:00:00.000Z" agent="codex" version="24.7.17" type="device">
  <diagram id="v11-gap-current-target" name="01 当前架构 vs 目标架构差异">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title1" value="V1.1 当前架构 vs 目标架构差异&lt;br&gt;目标：从工程型注入面板升级为可对照 Figma 的高保真前端体验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;fontSize=22;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="1280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="current" value="当前 V1.0 架构&lt;br&gt;&lt;br&gt;Content Script&lt;br&gt;- 注入普通网页&lt;br&gt;&lt;br&gt;Shadow DOM injectedPanel&lt;br&gt;- 字符串模板&lt;br&gt;- 内联 CSS&lt;br&gt;- 工程可用样式&lt;br&gt;&lt;br&gt;Runtime API&lt;br&gt;- PageContext&lt;br&gt;- SSE Chat&lt;br&gt;- Session restore&lt;br&gt;&lt;br&gt;AgentCore&lt;br&gt;- StateMachine&lt;br&gt;- Tool / Trace / Governance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontSize=15;align=left;spacingLeft=16" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="330" height="430" as="geometry" />
        </mxCell>
        <mxCell id="target" value="V1.1 目标架构&lt;br&gt;&lt;br&gt;Figma 组件语义&lt;br&gt;- MainLayout&lt;br&gt;- MockPage&lt;br&gt;- FloatingBall&lt;br&gt;- Sidebar&lt;br&gt;- ChatArea&lt;br&gt;&lt;br&gt;真实注入面板映射&lt;br&gt;- Floating Entry&lt;br&gt;- Panel Shell&lt;br&gt;- Left Rail&lt;br&gt;- Chat Workspace&lt;br&gt;- Tool Dock&lt;br&gt;- Artifact Viewer&lt;br&gt;- Visual Tokens&lt;br&gt;&lt;br&gt;Runtime / AgentCore 合同不变" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;fontSize=15;align=left;spacingLeft=16" vertex="1" parent="1">
          <mxGeometry x="980" y="160" width="330" height="430" as="geometry" />
        </mxCell>
        <mxCell id="gap" value="核心差异 / Gap&lt;br&gt;&lt;br&gt;1. 结构：工程模板 -&gt; 组件语义&lt;br&gt;2. 样式：分散 CSS -&gt; visual tokens&lt;br&gt;3. 状态：可用展示 -&gt; 高保真空态 / 错误态 / streaming&lt;br&gt;4. 验收：DOM/E2E -&gt; Figma 对照 + 截图基线 + 真实 Chrome&lt;br&gt;5. Side Panel：调试入口，不参与 V1.1 高保真验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=15;align=left;spacingLeft=16" vertex="1" parent="1">
          <mxGeometry x="500" y="210" width="400" height="300" as="geometry" />
        </mxCell>
        <mxCell id="arrow1" value="保留功能链路&lt;br&gt;升级表现层" style="endArrow=block;html=1;rounded=0;strokeColor=#334155;strokeWidth=2;fontSize=13" edge="1" parent="1" source="current" target="gap">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow2" value="映射到 Figma 语义" style="endArrow=block;html=1;rounded=0;strokeColor=#334155;strokeWidth=2;fontSize=13" edge="1" parent="1" source="gap" target="target">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="guard1" value="不改变：Runtime API / AgentEvent / ToolResult / PageContext / Session / Governance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#4F46E5;fontSize=15;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="260" y="660" width="880" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v11-target-architecture" name="02 V1.1 目标架构">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
