          <mxGeometry x="80" y="170" width="250" height="210" as="geometry" />
        </mxCell>
        <mxCell id="ui" value="Injected Interface Plane&lt;br&gt;&lt;br&gt;Floating Entry&lt;br&gt;Panel Shell&lt;br&gt;Left Rail&lt;br&gt;Chat Workspace&lt;br&gt;Tool Dock&lt;br&gt;Artifact Viewer&lt;br&gt;Visual Tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#16A34A;fontSize=15;align=center" vertex="1" parent="1">
