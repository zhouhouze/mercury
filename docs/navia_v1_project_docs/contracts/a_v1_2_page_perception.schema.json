{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://navia.local/contracts/a_v1_2_page_perception.schema.json",
  "title": "Navia A-V1.2 Page Perception Contracts",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/HighSignalPageContext" },
    { "$ref": "#/$defs/PerceptionDigest" },
    { "$ref": "#/$defs/SourceMap" },
    { "$ref": "#/$defs/PagePerceptionQualityReport" },
    { "$ref": "#/$defs/CandidateExtractionResult" },
    { "$ref": "#/$defs/DebugEvidenceBundle" },
    { "$ref": "#/$defs/CorpusPageRecord" },
    { "$ref": "#/$defs/GoldEvaluationRecord" },
    { "$ref": "#/$defs/ExtractorComparisonReport" }
  ],
  "$defs": {
    "Id": {
      "type": "string",
      "minLength": 1
    },
    "Hash": {
      "type": "string",
      "pattern": "^sha256_[a-f0-9]{16,64}$"
    },
    "Score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ReadinessStatus": {
      "type": "string",
      "enum": ["pass", "degraded", "fail"]
    },
    "ExtractorName": {
      "type": "string",
      "enum": ["dom_baseline", "trafilatura", "readability_lxml", "readabilipy"]
    },
    "CorpusCategory": {
      "type": "string",
      "enum": [
        "news_article",
        "longform_blog",
        "technical_docs",
        "github_readme",
        "product_docs",
        "ecommerce_product",
        "forum_thread",
        "academic_or_report",
        "table_heavy_page",
        "code_heavy_page",
        "image_rich_article",
        "localized_chinese_page",
        "low_signal_or_paywall_like"
      ]
    },
    "ComplexityTag": {
      "type": "string",
      "enum": [
        "multi_column",
        "sidebar",
        "recommendation",
        "ads",
        "comments",
        "paywall_like",
        "longform",
        "table_heavy",
        "code_heavy",
        "image_rich",
        "mixed_language",
        "spa_like",
        "low_signal"
      ]
    },
    "PageMetadata": {
      "type": "object",
      "required": ["wordCount", "paragraphCount", "headingCount"],
      "properties": {
        "language": { "type": "string" },
        "contentType": {
          "type": "string",
          "enum": ["article", "documentation", "readme", "search_result", "unknown"]
        },
        "author": { "type": "string" },
        "publishedAt": { "type": "string" },
        "siteName": { "type": "string" },
        "canonicalUrl": { "type": "string" },
        "wordCount": { "type": "integer", "minimum": 0 },
        "paragraphCount": { "type": "integer", "minimum": 0 },
        "headingCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "BlockType": {
      "type": "string",
      "enum": [
        "paragraph",
        "chunk",
        "heading",
        "image",
        "table",
        "table_cell",
        "code",
        "list_item",
        "quote"
      ]
    },
    "RegionType": {
      "type": "string",
      "enum": [
        "main",
        "article",
        "section",
        "metadata",
        "aside",
        "nav",
        "footer",
        "recommendation",
        "comment",
        "ad_like",
        "unknown"
      ]
    },
    "SourceRef": {
      "type": "object",
      "required": [
        "sourceRefId",
        "pageId",
        "contentHash",
        "blockId",
        "blockType",
        "order",
        "textQuote",
        "textHash",
        "fallbackText",
        "confidence"
      ],
      "properties": {
        "sourceRefId": { "$ref": "#/$defs/Id" },
        "pageId": { "$ref": "#/$defs/Id" },
        "contentHash": { "$ref": "#/$defs/Hash" },
        "blockId": { "$ref": "#/$defs/Id" },
        "blockType": { "$ref": "#/$defs/BlockType" },
        "order": { "type": "integer", "minimum": 0 },
        "paragraphId": { "$ref": "#/$defs/Id" },
        "chunkId": { "$ref": "#/$defs/Id" },
        "headingPath": {
          "type": "array",
          "items": { "type": "string" }
        },
        "textQuote": { "type": "string", "minLength": 1 },
        "textHash": { "$ref": "#/$defs/Hash" },
        "selector": { "type": "string" },
        "domPath": { "type": "string" },
        "startOffset": { "type": "integer", "minimum": 0 },
        "endOffset": { "type": "integer", "minimum": 0 },
        "fallbackText": { "type": "string", "minLength": 1 },
        "confidence": { "$ref": "#/$defs/Score" }
      },
      "additionalProperties": false
    },
    "SourceMap": {
      "type": "object",
      "required": ["schemaVersion", "sourceMapId", "pageId", "contentHash", "status", "sourceRefs"],
      "properties": {
        "schemaVersion": { "const": "a-v1.2-source-map-2026-06-05" },
        "sourceMapId": { "$ref": "#/$defs/Id" },
        "pageId": { "$ref": "#/$defs/Id" },
        "contentHash": { "$ref": "#/$defs/Hash" },
        "status": { "$ref": "#/$defs/ReadinessStatus" },
        "sourceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceRef" }
        }
      },
      "additionalProperties": false
    },
    "HighSignalBlock": {
      "type": "object",
      "required": [
        "blockId",
        "pageId",
        "contentHash",
        "blockType",
        "order",
        "text",
        "paragraphIds",
        "chunkIds",
        "sourceRefs",
        "regionType",
        "contentDensityScore",
        "noiseScore",
        "importance",
        "confidence",
        "warnings"
      ],
      "properties": {
        "blockId": { "$ref": "#/$defs/Id" },
        "pageId": { "$ref": "#/$defs/Id" },
        "contentHash": { "$ref": "#/$defs/Hash" },
        "blockType": { "$ref": "#/$defs/BlockType" },
        "order": { "type": "integer", "minimum": 0 },
        "text": { "type": "string", "minLength": 1 },
        "paragraphIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" }
        },
        "chunkIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" }
        },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/SourceRef" }
        },
        "regionType": { "$ref": "#/$defs/RegionType" },
        "contentDensityScore": { "$ref": "#/$defs/Score" },
        "noiseScore": { "$ref": "#/$defs/Score" },
        "importance": { "$ref": "#/$defs/Score" },
        "confidence": { "$ref": "#/$defs/Score" },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "FilteredBlockEvidence": {
      "type": "object",
      "required": [
        "blockId",
        "pageId",
        "contentHash",
        "blockType",
        "order",
        "textQuote",
        "textHash",
        "regionType",
        "noiseScore",
        "reason",
        "sourceRefs"
      ],
      "properties": {
        "blockId": { "$ref": "#/$defs/Id" },
        "pageId": { "$ref": "#/$defs/Id" },
        "contentHash": { "$ref": "#/$defs/Hash" },
        "blockType": { "$ref": "#/$defs/BlockType" },
        "order": { "type": "integer", "minimum": 0 },
        "textQuote": { "type": "string", "minLength": 1 },
        "textHash": { "$ref": "#/$defs/Hash" },
        "regionType": { "$ref": "#/$defs/RegionType" },
        "noiseScore": { "$ref": "#/$defs/Score" },
        "reason": {
          "type": "string",
          "enum": [
            "navigation",
            "footer",
            "aside",
            "recommendation",
            "comment",
            "ad_like",
            "duplicate",
            "low_signal",
            "unknown"
          ]
        },
        "sourceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceRef" }
        }
      },
      "additionalProperties": false
    },
    "HighSignalPageContext": {
      "type": "object",
      "required": [
        "schemaVersion",
        "pageId",
        "sessionId",
        "contentHash",
        "sourceStructuredPageRef",
        "metadata",
        "highSignalBlocks",
        "filteredBlocks",
        "sourceMapRef",
        "qualityReportRef",
        "status",
        "warnings"
      ],
      "properties": {
        "schemaVersion": { "const": "a-v1.2-page-perception-2026-06-05" },
        "pageId": { "$ref": "#/$defs/Id" },
        "sessionId": { "$ref": "#/$defs/Id" },
        "contentHash": { "$ref": "#/$defs/Hash" },
        "sourceStructuredPageRef": {
          "type": "object",
          "required": ["pageId", "contentHash"],
          "properties": {
            "pageId": { "$ref": "#/$defs/Id" },
            "contentHash": { "$ref": "#/$defs/Hash" }
          },
          "additionalProperties": false
        },
        "metadata": { "$ref": "#/$defs/PageMetadata" },
        "highSignalBlocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/HighSignalBlock" }
        },
        "filteredBlocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/FilteredBlockEvidence" }
        },
        "sourceMapRef": { "$ref": "#/$defs/Id" },
        "digestRef": { "$ref": "#/$defs/Id" },
        "qualityReportRef": { "$ref": "#/$defs/Id" },
        "status": { "type": "string", "enum": ["ready", "degraded", "failed"] },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "PerceptionDigestItem": {
      "type": "object",
      "required": [
        "itemId",
        "kind",
        "text",
        "importance",
        "confidence",
        "sourceRefs",
        "relatedParagraphIds",
        "relatedChunkIds",
        "warnings"
      ],
      "properties": {
        "itemId": { "$ref": "#/$defs/Id" },
        "kind": {
          "type": "string",
          "enum": [
            "key_fact",
            "entity",
            "claim",
            "evidence",
            "definition",
            "procedure",
            "open_question",
            "table_fact",
            "code_fact",
            "image_metadata"
          ]
        },
        "text": { "type": "string", "minLength": 1 },
        "importance": { "$ref": "#/$defs/Score" },
        "confidence": { "$ref": "#/$defs/Score" },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/SourceRef" }
        },
        "relatedParagraphIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" }
        },
        "relatedChunkIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "PerceptionDigest": {
      "type": "object",
      "required": ["schemaVersion", "digestId", "pageId", "contentHash", "status", "items", "rejectedItems", "summary", "stats"],
      "properties": {
        "schemaVersion": { "const": "a-v1.2-perception-digest-2026-06-05" },
        "digestId": { "$ref": "#/$defs/Id" },
        "pageId": { "$ref": "#/$defs/Id" },
        "contentHash": { "$ref": "#/$defs/Hash" },
        "status": { "$ref": "#/$defs/ReadinessStatus" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/PerceptionDigestItem" }
        },
        "rejectedItems": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["itemId", "text", "reason", "warnings"],
            "properties": {
              "itemId": { "$ref": "#/$defs/Id" },
              "text": { "type": "string" },
              "reason": {
                "type": "string",
                "enum": ["missing_source_ref", "low_confidence", "duplicate", "low_signal"]
              },
              "warnings": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "summary": {
          "type": "object",
          "required": ["tldr", "keyTakeaways"],
          "properties": {
            "tldr": { "type": "string" },
            "keyTakeaways": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "stats": {
          "type": "object",
          "required": ["itemCount", "sourceRefCount", "compressionRatio"],
          "properties": {
            "itemCount": { "type": "integer", "minimum": 0 },
            "sourceRefCount": { "type": "integer", "minimum": 0 },
            "compressionRatio": { "$ref": "#/$defs/Score" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "QualityMetric": {
      "type": "object",
      "required": ["value", "numerator", "denominator", "method", "threshold", "passed", "denominatorZeroBehavior"],
      "properties": {
        "value": { "type": "number" },
        "numerator": { "type": "number" },
        "denominator": { "type": "number" },
        "method": { "type": "string", "minLength": 1 },
        "threshold": { "type": "number" },
        "passed": { "type": "boolean" },
        "denominatorZeroBehavior": {
          "type": "string",
          "enum": ["pass_when_empty", "fail_when_empty", "degrade_when_empty", "not_applicable"]
        }
      },
      "additionalProperties": false
    },
    "QualityIssue": {
      "type": "object",
      "required": ["code", "message", "severity", "relatedIds"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["warning", "major", "fatal"] },
        "relatedIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" }
        }
      },
      "additionalProperties": false
    },
    "PagePerceptionQualityReport": {
      "type": "object",
      "required": [
        "schemaVersion",
        "reportId",
        "pageId",
        "contentHash",
        "status",
        "overallScore",
        "overallFormula",
        "overallWeights",
        "lowSignalHandling",
        "metrics",
        "downstreamReadiness",
        "fatalIssues",
        "warnings"
      ],
      "properties": {
        "schemaVersion": { "const": "a-v1.2-quality-report-2026-06-05" },
        "reportId": { "$ref": "#/$defs/Id" },
        "pageId": { "$ref": "#/$defs/Id" },
        "contentHash": { "$ref": "#/$defs/Hash" },
        "status": { "$ref": "#/$defs/ReadinessStatus" },
        "overallScore": { "$ref": "#/$defs/Score" },
        "overallFormula": {
          "type": "string",
          "const": "0.20*sourceCoverage + 0.20*groundingCompleteness + 0.15*jumpbackCoverage + 0.15*(1-noiseRatio) + 0.10*contentCoverage + 0.10*compressionScore + 0.10*candidateFactDensity"
        },
        "overallWeights": {
          "type": "object",
          "required": [
            "sourceCoverage",
            "groundingCompleteness",
            "jumpbackCoverage",
            "inverseNoiseRatio",
            "contentCoverage",
            "compressionScore",
            "candidateFactDensity"
          ],
          "properties": {
            "sourceCoverage": { "const": 0.2 },
            "groundingCompleteness": { "const": 0.2 },
            "jumpbackCoverage": { "const": 0.15 },
            "inverseNoiseRatio": { "const": 0.15 },
            "contentCoverage": { "const": 0.1 },
            "compressionScore": { "const": 0.1 },
            "candidateFactDensity": { "const": 0.1 }
          },
          "additionalProperties": false
        },
        "lowSignalHandling": {
          "type": "string",
          "enum": ["fail", "degraded_with_reason"]
        },
        "metrics": {
          "type": "object",
          "required": [
            "noiseRatio",
            "contentCoverage",
            "sourceCoverage",
            "groundingCompleteness",
            "jumpbackCoverage",
            "digestCompressionRatio",
            "compressionScore",
            "candidateFactDensity"
          ],
          "properties": {
            "noiseRatio": { "$ref": "#/$defs/QualityMetric" },
            "contentCoverage": { "$ref": "#/$defs/QualityMetric" },
            "sourceCoverage": { "$ref": "#/$defs/QualityMetric" },
            "groundingCompleteness": { "$ref": "#/$defs/QualityMetric" },
            "jumpbackCoverage": { "$ref": "#/$defs/QualityMetric" },
            "digestCompressionRatio": { "$ref": "#/$defs/QualityMetric" },
            "compressionScore": { "$ref": "#/$defs/QualityMetric" },
            "candidateFactDensity": { "$ref": "#/$defs/QualityMetric" }
          },
          "additionalProperties": false
        },
        "downstreamReadiness": { "type": "string", "enum": ["pass", "degraded", "fail"] },
        "fatalIssues": {
          "type": "array",
          "items": { "$ref": "#/$defs/QualityIssue" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/QualityIssue" }
        }
      },
      "additionalProperties": false
    },
    "CandidateExtractionResult": {
      "type": "object",
      "required": ["extractorName", "warnings"],
      "properties": {
        "extractorName": {
          "type": "string",
          "enum": ["trafilatura", "readabilipy", "readability_lxml", "dom_baseline"]
        },
        "version": { "type": "string" },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "metadata": { "type": "object" },
        "blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["candidateBlockId", "order", "text"],
            "properties": {
              "candidateBlockId": { "$ref": "#/$defs/Id" },
              "order": { "type": "integer", "minimum": 0 },
              "text": { "type": "string" },
              "blockType": { "type": "string" },
              "metadata": { "type": "object" }
            },
            "additionalProperties": false
          }
        },
        "confidence": { "$ref": "#/$defs/Score" },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "ExtractorCandidateScore": {
      "type": "object",
      "required": [
        "extractorName",
        "status",
        "blockCount",
        "mainTextChars",
        "estimatedNoiseRatio",
        "headingCoverage",
        "sourceRefCoverage",
        "score",
        "rejectionReason",
        "warnings"
      ],
      "properties": {
        "extractorName": { "$ref": "#/$defs/ExtractorName" },
        "status": {
          "type": "string",
          "enum": ["available", "unavailable", "skipped", "failed", "rejected"]
        },
        "blockCount": { "type": "integer", "minimum": 0 },
        "mainTextChars": { "type": "integer", "minimum": 0 },
        "estimatedNoiseRatio": { "$ref": "#/$defs/Score" },
        "headingCoverage": { "$ref": "#/$defs/Score" },
        "sourceRefCoverage": { "$ref": "#/$defs/Score" },
        "score": { "$ref": "#/$defs/Score" },
        "rejectionReason": {
          "type": "string",
          "enum": ["none", "unavailable", "failed", "low_source_ref_coverage", "high_noise", "low_main_text", "dependency_not_approved"]
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "ExtractorComparisonReport": {
      "type": "object",
      "required": [
        "schemaVersion",
        "pageKey",
        "pageId",
        "contentHash",
        "selectionFormula",
        "winner",
        "fallbackUsed",
        "fallbackReason",
        "tieBreaker",
        "candidates",
        "warnings"
      ],
      "properties": {
        "schemaVersion": { "const": "a-v1.2-extractor-comparison-2026-06-05" },
        "pageKey": { "$ref": "#/$defs/Id" },
        "pageId": { "$ref": "#/$defs/Id" },
        "contentHash": { "$ref": "#/$defs/Hash" },
        "selectionFormula": {
          "type": "string",
          "const": "0.35*sourceRefCoverage + 0.25*(1-estimatedNoiseRatio) + 0.20*headingCoverage + 0.20*mainTextCoverage"
        },
        "winner": { "$ref": "#/$defs/ExtractorName" },
        "fallbackUsed": { "type": "boolean" },
        "fallbackReason": {
          "type": "string",
          "enum": ["none", "winner_failed", "dependency_not_approved", "tie_to_dom_baseline", "all_candidates_rejected"]
        },
        "tieBreaker": {
          "type": "string",
          "const": "highest_score_then_dom_baseline_then_sourceRefCoverage_then_mainTextChars"
        },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ExtractorCandidateScore" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "DebugAuditStep": {
      "type": "object",
      "required": ["step", "status", "summary"],
      "properties": {
        "step": {
          "type": "string",
          "enum": ["extraction", "filtering", "digest", "source_map", "quality"]
        },
        "status": { "$ref": "#/$defs/ReadinessStatus" },
        "summary": { "type": "string", "minLength": 1 },
        "relatedIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" }
        }
      },
      "additionalProperties": false
    },
    "DebugEvidenceBundle": {
      "type": "object",
      "required": [
        "schemaVersion",
        "pageId",
        "contentHash",
        "status",
        "statusReason",
        "rawSignals",
        "candidateExtraction",
        "filteredEvidence",
        "highSignalPage",
        "sourceMap",
        "perceptionDigest",
        "qualityReport",
        "auditTrail",
        "warnings"
      ],
      "properties": {
        "schemaVersion": { "const": "a-v1.2-debug-evidence-2026-06-05" },
        "pageId": { "$ref": "#/$defs/Id" },
        "contentHash": { "$ref": "#/$defs/Hash" },
        "status": { "$ref": "#/$defs/ReadinessStatus" },
        "statusReason": { "type": "string", "minLength": 1 },
        "rawSignals": {
          "type": "object",
          "required": [
            "url",
            "title",
            "capturedAt",
            "htmlAvailable",
            "visibleTextLength",
            "cleanedTextLength",
            "headingCount",
            "imageCount",
            "tableCount",
            "codeBlockCount",
            "linkCount"
          ],
          "properties": {
            "url": { "type": "string", "minLength": 1 },
            "title": { "type": "string" },
            "domain": { "type": "string" },
            "capturedAt": { "type": "string" },
            "htmlAvailable": { "type": "boolean" },
            "visibleTextLength": { "type": "integer", "minimum": 0 },
            "cleanedTextLength": { "type": "integer", "minimum": 0 },
            "headingCount": { "type": "integer", "minimum": 0 },
            "imageCount": { "type": "integer", "minimum": 0 },
            "tableCount": { "type": "integer", "minimum": 0 },
            "codeBlockCount": { "type": "integer", "minimum": 0 },
            "linkCount": { "type": "integer", "minimum": 0 },
            "languageHint": { "type": "string" }
          },
          "additionalProperties": false
        },
        "candidateExtraction": { "$ref": "#/$defs/ExtractorComparisonReport" },
        "filteredEvidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/FilteredBlockEvidence" }
        },
        "highSignalPage": { "$ref": "#/$defs/HighSignalPageContext" },
        "sourceMap": { "$ref": "#/$defs/SourceMap" },
        "perceptionDigest": { "$ref": "#/$defs/PerceptionDigest" },
        "qualityReport": { "$ref": "#/$defs/PagePerceptionQualityReport" },
        "auditTrail": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/DebugAuditStep" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "CorpusPageRecord": {
      "type": "object",
      "required": [
        "schemaVersion",
        "pageKey",
        "url",
        "snapshotPath",
        "category",
        "language",
        "complexityTags",
        "expectedRisks",
        "goldStatus",
        "allowedNetworkAtCapture",
        "expectedOutcome"
      ],
      "properties": {
        "schemaVersion": { "const": "a-v1.2-corpus-page-2026-06-05" },
        "pageKey": { "$ref": "#/$defs/Id" },
        "url": { "type": "string", "minLength": 1 },
        "snapshotPath": { "type": "string", "minLength": 1 },
        "category": { "$ref": "#/$defs/CorpusCategory" },
        "language": { "type": "string", "enum": ["en", "zh", "mixed", "unknown"] },
        "complexityTags": {
          "type": "array",
          "items": { "$ref": "#/$defs/ComplexityTag" }
        },
        "expectedRisks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "goldStatus": { "type": "string", "enum": ["reviewed", "semi_auto_accepted"] },
        "allowedNetworkAtCapture": { "type": "boolean" },
        "capturedAt": { "type": "string" },
        "sourceLicenseNote": { "type": "string" },
        "expectedOutcome": { "$ref": "#/$defs/ReadinessStatus" }
      },
      "additionalProperties": false
    },
    "GoldEvaluationRecord": {
      "type": "object",
      "required": [
        "schemaVersion",
        "pageKey",
        "reviewedBy",
        "reviewedAt",
        "goldMainContentBlocks",
        "goldRejectedNoiseBlocks",
        "goldDigestItems",
        "goldSourceRefs",
        "reviewNotes"
      ],
      "properties": {
        "schemaVersion": { "const": "a-v1.2-gold-evaluation-2026-06-05" },
        "pageKey": { "$ref": "#/$defs/Id" },
        "reviewedBy": { "type": "string", "enum": ["human", "semi_auto_accepted"] },
        "reviewedAt": { "type": "string" },
        "goldMainContentBlocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" }
        },
        "goldRejectedNoiseBlocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/Id" }
        },
        "goldDigestItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/PerceptionDigestItem" }
        },
        "goldSourceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceRef" }
        },
        "reviewNotes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
